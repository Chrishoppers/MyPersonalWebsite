@model List<MyPersonalWebsite.Models.Message>

@{
    ViewData["Title"] = "留言审核管理";
    var isAdmin = Context.Session.GetInt32("IsAdmin") ?? 0;
    if (isAdmin != 1)
    {
        Context.Response.Redirect("/Auth/Login");
        return;
    }
}

<style>
    /* ===== 全局样式 ===== */
    body {
        background: #0b0e1a;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        color: #e0e0e0;
    }

    .admin-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
    }

    /* ===== 头部 ===== */
    .admin-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    }

    .admin-header h1 {
        font-size: 1.8rem;
        font-weight: 700;
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 50%, #4facfe 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin: 0;
    }

    .admin-header .header-actions {
        display: flex;
        gap: 0.8rem;
        flex-wrap: wrap;
    }

    .btn-glass {
        padding: 0.5rem 1.5rem;
        border-radius: 40px;
        border: 1px solid rgba(255, 255, 255, 0.06);
        background: rgba(255, 255, 255, 0.04);
        color: rgba(255, 255, 255, 0.7);
        font-weight: 500;
        text-decoration: none;
        transition: all 0.3s ease;
        font-size: 0.9rem;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
    }

    .btn-glass:hover {
        background: rgba(255, 255, 255, 0.08);
        border-color: rgba(255, 255, 255, 0.12);
        color: #fff;
        transform: translateY(-1px);
    }

    .btn-glass.primary {
        background: linear-gradient(135deg, #f5576c, #4facfe);
        border: none;
        color: #fff;
    }

    .btn-glass.primary:hover {
        transform: translateY(-2px) scale(1.02);
        box-shadow: 0 4px 20px rgba(245, 87, 108, 0.2);
    }

    .btn-glass.danger {
        background: rgba(220, 53, 69, 0.12);
        border-color: rgba(220, 53, 69, 0.15);
        color: #dc3545;
    }

    .btn-glass.danger:hover {
        background: rgba(220, 53, 69, 0.2);
    }

    /* ===== 统计卡片 ===== */
    .stats-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .stat-card {
        background: rgba(255, 255, 255, 0.03);
        border-radius: 16px;
        padding: 1rem 1.5rem;
        border: 1px solid rgba(255, 255, 255, 0.04);
        text-align: center;
        backdrop-filter: blur(10px);
    }

    .stat-card .number {
        font-size: 1.8rem;
        font-weight: 700;
        color: #fff;
    }

    .stat-card .label {
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.4);
        margin-top: 0.2rem;
    }

    .stat-card.pending .number { color: #ffc107; }
    .stat-card.approved .number { color: #28a745; }
    .stat-card.total .number { color: #4facfe; }
    .stat-card.reported .number { color: #dc3545; }

    /* ===== 筛选工具栏 ===== */
    .filter-bar {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: 1.5rem;
        padding: 1rem 1.5rem;
        background: rgba(255, 255, 255, 0.02);
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.04);
        align-items: center;
    }

    .filter-bar select,
    .filter-bar input {
        padding: 0.5rem 1rem;
        border-radius: 40px;
        border: 1px solid rgba(255, 255, 255, 0.06);
        background: rgba(255, 255, 255, 0.04);
        color: #e0e0e0;
        font-size: 0.9rem;
        outline: none;
        transition: border-color 0.2s ease;
        min-width: 140px;
    }

    .filter-bar select:focus,
    .filter-bar input:focus {
        border-color: rgba(79, 172, 254, 0.3);
    }

    .filter-bar select option {
        background: #1a1a2e;
        color: #e0e0e0;
    }

    .filter-bar .search-input {
        flex: 1;
        min-width: 200px;
    }

    .filter-bar .search-input::placeholder {
        color: rgba(255, 255, 255, 0.2);
    }

    .filter-bar .filter-label {
        color: rgba(255, 255, 255, 0.4);
        font-size: 0.85rem;
    }

    /* ===== 留言列表 ===== */
    .message-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .message-item {
        background: rgba(255, 255, 255, 0.03);
        border-radius: 16px;
        padding: 1.2rem 1.5rem;
        border: 1px solid rgba(255, 255, 255, 0.04);
        transition: all 0.3s ease;
        display: flex;
        gap: 1.2rem;
        align-items: flex-start;
        flex-wrap: wrap;
    }

    .message-item:hover {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(255, 255, 255, 0.08);
    }

    .message-item.pending {
        border-left: 3px solid #ffc107;
    }

    .message-item.reported {
        border-left: 3px solid #dc3545;
    }

    .message-item .avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: linear-gradient(135deg, #f093fb, #f5576c);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.9rem;
        color: #fff;
        flex-shrink: 0;
    }

    .message-item .body {
        flex: 1;
        min-width: 200px;
    }

    .message-item .body .meta {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        flex-wrap: wrap;
        margin-bottom: 0.3rem;
    }

    .message-item .body .meta .name {
        font-weight: 600;
        color: #fff;
    }

    .message-item .body .meta .email {
        color: rgba(255, 255, 255, 0.3);
        font-size: 0.8rem;
    }

    .message-item .body .meta .time {
        color: rgba(255, 255, 255, 0.2);
        font-size: 0.75rem;
    }

    .message-item .body .meta .badge {
        font-size: 0.65rem;
        padding: 0.1rem 0.6rem;
        border-radius: 20px;
        font-weight: 500;
    }

    .badge-pending {
        background: rgba(255, 193, 7, 0.15);
        color: #ffc107;
        border: 1px solid rgba(255, 193, 7, 0.1);
    }

    .badge-approved {
        background: rgba(40, 167, 69, 0.15);
        color: #28a745;
        border: 1px solid rgba(40, 167, 69, 0.1);
    }

    .badge-reported {
        background: rgba(220, 53, 69, 0.15);
        color: #dc3545;
        border: 1px solid rgba(220, 53, 69, 0.1);
    }

    .badge-admin {
        background: rgba(79, 172, 254, 0.15);
        color: #4facfe;
        border: 1px solid rgba(79, 172, 254, 0.1);
    }

    .message-item .body .content {
        color: rgba(255, 255, 255, 0.8);
        font-size: 0.95rem;
        line-height: 1.5;
        word-break: break-word;
    }

    .message-item .body .reply-section {
        margin-top: 0.8rem;
        padding: 0.8rem 1rem;
        background: rgba(79, 172, 254, 0.04);
        border-radius: 12px;
        border-left: 2px solid rgba(79, 172, 254, 0.2);
    }

    .message-item .body .reply-section .reply-label {
        font-size: 0.7rem;
        color: rgba(79, 172, 254, 0.5);
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .message-item .body .reply-section .reply-content {
        color: rgba(255, 255, 255, 0.7);
        font-size: 0.9rem;
        margin-top: 0.2rem;
    }

    .message-item .actions {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        align-items: center;
        flex-shrink: 0;
    }

    .message-item .actions .btn-sm {
        padding: 0.3rem 1rem;
        border-radius: 30px;
        border: none;
        font-size: 0.8rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s ease;
        background: rgba(255, 255, 255, 0.04);
        color: rgba(255, 255, 255, 0.6);
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
    }

    .message-item .actions .btn-sm:hover {
        background: rgba(255, 255, 255, 0.08);
        color: #fff;
        transform: scale(1.02);
    }

    .message-item .actions .btn-approve {
        background: rgba(40, 167, 69, 0.12);
        color: #28a745;
    }

    .message-item .actions .btn-approve:hover {
        background: rgba(40, 167, 69, 0.2);
    }

    .message-item .actions .btn-delete {
        background: rgba(220, 53, 69, 0.08);
        color: #dc3545;
    }

    .message-item .actions .btn-delete:hover {
        background: rgba(220, 53, 69, 0.15);
    }

    .message-item .actions .btn-reply {
        background: rgba(79, 172, 254, 0.08);
        color: #4facfe;
    }

    .message-item .actions .btn-reply:hover {
        background: rgba(79, 172, 254, 0.15);
    }

    .message-item .actions .like-count {
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.3);
        display: flex;
        align-items: center;
        gap: 0.2rem;
    }

    /* ===== 空状态 ===== */
    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        background: rgba(255, 255, 255, 0.02);
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.04);
    }

    .empty-state .icon {
        font-size: 4rem;
        margin-bottom: 1rem;
        opacity: 0.3;
    }

    .empty-state h3 {
        color: rgba(255, 255, 255, 0.5);
        font-weight: 500;
    }

    .empty-state p {
        color: rgba(255, 255, 255, 0.2);
    }

    /* ===== 回复弹窗 ===== */
    .reply-modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.5);
        backdrop-filter: blur(8px);
        z-index: 1000;
        align-items: center;
        justify-content: center;
    }

    .reply-modal-overlay.active {
        display: flex;
    }

    .reply-modal {
        background: #1a1a2e;
        border-radius: 28px;
        padding: 2rem 2.2rem;
        max-width: 500px;
        width: 90%;
        border: 1px solid rgba(255, 255, 255, 0.04);
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.4);
        animation: modalIn 0.3s ease;
    }

    .reply-modal h5 {
        font-weight: 600;
        margin-bottom: 0.5rem;
        color: #fff;
    }

    .reply-modal textarea {
        width: 100%;
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 16px;
        padding: 0.8rem 1rem;
        background: rgba(255, 255, 255, 0.04);
        color: #fff;
        font-size: 0.95rem;
        resize: vertical;
        min-height: 100px;
        transition: border-color 0.2s ease;
        font-family: inherit;
    }

    .reply-modal textarea:focus {
        outline: none;
        border-color: rgba(79, 172, 254, 0.3);
    }

    .reply-modal textarea::placeholder {
        color: rgba(255, 255, 255, 0.2);
    }

    .reply-modal .modal-actions {
        display: flex;
        gap: 0.5rem;
        margin-top: 1rem;
        justify-content: flex-end;
    }

    .reply-modal .modal-actions button {
        padding: 0.6rem 1.8rem;
        border: none;
        border-radius: 40px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s ease;
        font-size: 0.9rem;
    }

    .reply-modal .btn-submit {
        background: linear-gradient(135deg, #f5576c, #4facfe);
        color: #fff;
    }

    .reply-modal .btn-submit:hover {
        transform: scale(1.02);
        box-shadow: 0 4px 20px rgba(245, 87, 108, 0.2);
    }

    .reply-modal .btn-cancel {
        background: rgba(255, 255, 255, 0.04);
        color: rgba(255, 255, 255, 0.4);
    }

    .reply-modal .btn-cancel:hover {
        background: rgba(255, 255, 255, 0.08);
    }

    @@keyframes modalIn {
        from {
            opacity: 0;
            transform: scale(0.95) translateY(20px);
        }
        to {
            opacity: 1;
            transform: scale(1) translateY(0);
        }
    }

    /* ===== Toast ===== */
    .toast-container {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        z-index: 2000;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        align-items: flex-end;
    }

    .toast-msg {
        padding: 0.8rem 1.8rem;
        border-radius: 40px;
        color: #fff;
        font-weight: 500;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
        animation: slideUp 0.4s ease;
        font-size: 0.9rem;
        backdrop-filter: blur(10px);
        background: rgba(0, 0, 0, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.04);
    }

    .toast-msg.success { background: rgba(40, 167, 69, 0.8); }
    .toast-msg.error { background: rgba(220, 53, 69, 0.8); }
    .toast-msg.info { background: rgba(79, 172, 254, 0.8); }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(20px) scale(0.95);
        }
        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    /* ===== 响应式 ===== */
    @@media (max-width: 768px) {
        .admin-header {
            flex-direction: column;
            align-items: stretch;
        }
        .admin-header h1 {
            font-size: 1.4rem;
        }
        .filter-bar {
            flex-direction: column;
            align-items: stretch;
        }
        .filter-bar .search-input {
            min-width: 100%;
        }
        .message-item {
            flex-direction: column;
        }
        .message-item .actions {
            width: 100%;
            justify-content: flex-start;
        }
        .stats-row {
            grid-template-columns: repeat(2, 1fr);
        }
    }
</style>

<div class="admin-container">
    <!-- ===== 头部 ===== -->
    <div class="admin-header">
        <h1>📋 留言审核管理</h1>
        <div class="header-actions">
            <a href="/Admin/Dashboard" class="btn-glass">
                ← 返回后台
            </a>
            <a href="/Message/Index" class="btn-glass primary" target="_blank">
                👁️ 查看大屏
            </a>
        </div>
    </div>

    <!-- ===== 统计卡片 ===== -->
    <div class="stats-row">
        <div class="stat-card total">
            <div class="number">@Model.Count</div>
            <div class="label">📝 总留言</div>
        </div>
        <div class="stat-card pending">
            <div class="number">@Model.Count(m => !m.IsApproved)</div>
            <div class="label">⏳ 待审核</div>
        </div>
        <div class="stat-card approved">
            <div class="number">@Model.Count(m => m.IsApproved)</div>
            <div class="label">✅ 已通过</div>
        </div>
        <div class="stat-card reported">
            <div class="number">@Model.Count(m => m.IsReported)</div>
            <div class="label">🚩 被举报</div>
        </div>
    </div>

    <!-- ===== 筛选工具栏 ===== -->
    <div class="filter-bar">
        <span class="filter-label">🔍 筛选：</span>
        <select id="filterStatus">
            <option value="all">全部</option>
            <option value="pending">⏳ 待审核</option>
            <option value="approved">✅ 已通过</option>
            <option value="reported">🚩 已举报</option>
        </select>
        <input type="text" class="search-input" id="searchInput" placeholder="搜索用户名或内容..." />
        <button class="btn-glass" onclick="applyFilters()">应用筛选</button>
        <button class="btn-glass" onclick="resetFilters()">重置</button>
    </div>

    <!-- ===== 留言列表 ===== -->
    <div class="message-list" id="messageList">
        @if (Model.Any())
        {
            foreach (var msg in Model)
            {
                <div class="message-item @(!msg.IsApproved ? "pending" : "") @(msg.IsReported ? "reported" : "")"
                     data-status="@(msg.IsApproved ? "approved" : "pending")"
                     data-reported="@(msg.IsReported ? "true" : "false")"
                     data-search="@(msg.VisitorName + " " + msg.Content + " " + msg.Email)">
                    
                    <div class="avatar">@(msg.VisitorName.FirstOrDefault().ToString().ToUpper())</div>

                    <div class="body">
                        <div class="meta">
                            <span class="name">@msg.VisitorName</span>
                            <span class="email">@msg.Email</span>
                            <span class="time">@msg.CreateTime.ToString("yyyy-MM-dd HH:mm")</span>
                            @if (msg.User?.IsAdmin == true)
                            {
                                <span class="badge badge-admin">👑 管理员</span>
                            }
                            @if (!msg.IsApproved)
                            {
                                <span class="badge badge-pending">⏳ 待审核</span>
                            }
                            else
                            {
                                <span class="badge badge-approved">✅ 已通过</span>
                            }
                            @if (msg.IsReported)
                            {
                                <span class="badge badge-reported">🚩 已举报</span>
                            }
                            <span class="like-count">❤️ @msg.LikeCount</span>
                        </div>

                        <div class="content">@msg.Content</div>

                        @if (!string.IsNullOrEmpty(msg.AdminReply))
                        {
                            <div class="reply-section">
                                <div class="reply-label">👨‍💼 管理员回复</div>
                                <div class="reply-content">@msg.AdminReply</div>
                            </div>
                        }
                    </div>

                    <div class="actions">
                        @if (!msg.IsApproved)
                        {
                            <button class="btn-sm btn-approve" onclick="approveMessage(@msg.Id)">
                                ✅ 通过
                            </button>
                        }
                        <button class="btn-sm btn-reply" onclick="openReplyModal(@msg.Id)">
                            💬 回复
                        </button>
                        <button class="btn-sm btn-delete" onclick="deleteMessage(@msg.Id)">
                            🗑️ 删除
                        </button>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <div class="icon">💬</div>
                <h3>暂无留言</h3>
                <p>还没有人发布留言</p>
            </div>
        }
    </div>
</div>

<!-- ===== 回复弹窗 ===== -->
<div class="reply-modal-overlay" id="replyModal">
    <div class="reply-modal">
        <h5>💬 回复留言</h5>
        <textarea id="replyContent" placeholder="输入回复内容..."></textarea>
        <input type="hidden" id="replyMessageId" />
        <div class="modal-actions">
            <button class="btn-cancel" onclick="closeReplyModal()">取消</button>
            <button class="btn-submit" onclick="submitReply()">发送回复</button>
        </div>
    </div>
</div>

<!-- ===== Toast ===== -->
<div class="toast-container" id="toastContainer"></div>

@section Scripts {
    <script>
        // ============================================================
        // 1. 审核通过
        // ============================================================
        function approveMessage(id) {
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
            fetch('/Message/Approve', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: `id=${id}`
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    showToast('✅ 审核通过，留言已显示在大屏', 'success');
                    setTimeout(() => location.reload(), 800);
                } else {
                    showToast(data.message || '操作失败', 'error');
                }
            })
            .catch(() => showToast('操作失败，请重试', 'error'));
        }

        // ============================================================
        // 2. 删除留言
        // ============================================================
        function deleteMessage(id) {
            if (!confirm('确定要删除这条留言吗？此操作不可恢复。')) return;

            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
            fetch('/Message/Delete', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: `id=${id}`
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    showToast('🗑️ 删除成功', 'success');
                    setTimeout(() => location.reload(), 800);
                } else {
                    showToast(data.message || '删除失败', 'error');
                }
            })
            .catch(() => showToast('操作失败，请重试', 'error'));
        }

        // ============================================================
        // 3. 回复功能
        // ============================================================
        function openReplyModal(id) {
            document.getElementById('replyMessageId').value = id;
            document.getElementById('replyContent').value = '';
            document.getElementById('replyModal').classList.add('active');
        }

        function closeReplyModal() {
            document.getElementById('replyModal').classList.remove('active');
        }

        function submitReply() {
            const id = document.getElementById('replyMessageId').value;
            const content = document.getElementById('replyContent').value.trim();

            if (!content) {
                showToast('请输入回复内容', 'error');
                return;
            }

            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

            fetch('/Message/Reply', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: `messageId=${id}&replyContent=${encodeURIComponent(content)}`
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    closeReplyModal();
                    showToast('💬 回复成功，邮件已通知用户', 'success');
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showToast(data.message || '回复失败', 'error');
                }
            })
            .catch(() => showToast('操作失败，请重试', 'error'));
        }

        // 点击外部关闭弹窗
        document.getElementById('replyModal').addEventListener('click', function(e) {
            if (e.target === this) closeReplyModal();
        });

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closeReplyModal();
        });

        // ============================================================
        // 4. 筛选功能
        // ============================================================
        function applyFilters() {
            const status = document.getElementById('filterStatus').value;
            const search = document.getElementById('searchInput').value.toLowerCase();

            const items = document.querySelectorAll('.message-item');
            let visibleCount = 0;

            items.forEach(item => {
                let show = true;

                // 状态筛选
                if (status === 'pending' && item.dataset.status !== 'pending') show = false;
                else if (status === 'approved' && item.dataset.status !== 'approved') show = false;
                else if (status === 'reported' && item.dataset.reported !== 'true') show = false;

                // 搜索筛选
                if (show && search) {
                    const searchText = item.dataset.search?.toLowerCase() || '';
                    if (!searchText.includes(search)) show = false;
                }

                item.style.display = show ? 'flex' : 'none';
                if (show) visibleCount++;
            });

            showToast(`显示 ${visibleCount} 条留言`, 'info');
        }

        function resetFilters() {
            document.getElementById('filterStatus').value = 'all';
            document.getElementById('searchInput').value = '';
            document.querySelectorAll('.message-item').forEach(item => {
                item.style.display = 'flex';
            });
            showToast('已重置筛选', 'info');
        }

        // 回车键触发搜索
        document.getElementById('searchInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') applyFilters();
        });

        // ============================================================
        // 5. Toast 消息
        // ============================================================
        function showToast(message, type = 'info') {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast-msg ${type}`;
            toast.textContent = message;
            container.appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(20px)';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }
    </script>
}