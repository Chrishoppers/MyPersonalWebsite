@model List<MyPersonalWebsite.Models.User>

@{
    ViewData["Title"] = "待审核更改";
    var isAdmin = Context.Session.GetInt32("IsAdmin") ?? 0;
    if (isAdmin != 1)
    {
        Context.Response.Redirect("/Auth/Login");
        return;
    }
}

<style>
    .pending-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1rem;
    }

    .pending-container h2 {
        color: #fff;
        font-weight: 700;
        margin-bottom: 1.5rem;
    }

    .table-wrapper {
        background: rgba(255,255,255,0.02);
        border-radius: 20px;
        border: 1px solid rgba(255,255,255,0.04);
        overflow-x: auto;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        color: #e0e0e0;
        font-size: 0.9rem;
        min-width: 800px;
    }

    th {
        padding: 0.8rem 1rem;
        text-align: left;
        color: rgba(255,255,255,0.3);
        font-weight: 500;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        border-bottom: 1px solid rgba(255,255,255,0.04);
        background: rgba(255,255,255,0.02);
    }

    td {
        padding: 0.8rem 1rem;
        border-top: 1px solid rgba(255,255,255,0.02);
        vertical-align: middle;
    }

    .btn-action {
        padding: 0.2rem 0.8rem;
        border: none;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s ease;
        margin: 0.1rem 0.1rem;
    }

    .btn-approve {
        background: rgba(40,167,69,0.12);
        color: #28a745;
    }
    .btn-approve:hover {
        background: rgba(40,167,69,0.2);
    }

    .btn-reject {
        background: rgba(220,53,69,0.08);
        color: #dc3545;
    }
    .btn-reject:hover {
        background: rgba(220,53,69,0.15);
    }

    .avatar-preview-thumb {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid rgba(255,255,255,0.06);
        flex-shrink: 0;
    }

    .change-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .change-item .change-label {
        color: rgba(255,255,255,0.5);
        font-size: 0.8rem;
    }

    .empty-state {
        text-align: center;
        padding: 3rem 2rem;
        color: rgba(255,255,255,0.15);
    }

    @@media (max-width: 768px) {
        td, th {
            padding: 0.5rem 0.6rem;
            font-size: 0.75rem;
        }
        .avatar-preview-thumb {
            width: 30px;
            height: 30px;
        }
    }
</style>

<div class="pending-container">
    <h2>📋 待审核更改</h2>

    @{
        var hasPending = Model.Any(u =>
            !string.IsNullOrEmpty(u.PendingUsername) ||
            !string.IsNullOrEmpty(u.PendingEmail) ||
            (!u.IsAvatarApproved && !string.IsNullOrEmpty(u.AvatarUrl))
        );
    }

    @if (hasPending)
    {
        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>用户</th>
                        <th>更改类型</th>
                        <th>当前值</th>
                        <th>申请值</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        var hasUsernameChange = !string.IsNullOrEmpty(user.PendingUsername);
                        var hasEmailChange = !string.IsNullOrEmpty(user.PendingEmail);
                        var hasAvatarChange = !user.IsAvatarApproved && !string.IsNullOrEmpty(user.AvatarUrl);

                        if (!hasUsernameChange && !hasEmailChange && !hasAvatarChange) continue;

                        <tr>
                            <td style="padding:0.8rem 1rem;border-top:1px solid rgba(255,255,255,0.02);">
                                <strong style="color:#fff;">@user.Username</strong>
                            </td>

                            <td style="padding:0.8rem 1rem;border-top:1px solid rgba(255,255,255,0.02);">
                                @if (hasUsernameChange) { <span>昵称</span><br /> }
                                @if (hasEmailChange) { <span>邮箱</span><br /> }
                                @if (hasAvatarChange) { <span>头像</span> }
                            </td>

                            <td style="padding:0.8rem 1rem;border-top:1px solid rgba(255,255,255,0.02);">
                                @if (hasUsernameChange) { <span>@user.Username</span><br /> }
                                @if (hasEmailChange) { <span>@user.Email</span><br /> }
                                @if (hasAvatarChange)
                                {
                                    <span>当前头像</span>
                                    if (!string.IsNullOrEmpty(user.AvatarUrl))
                                    {
                                        <br />
                                        <img src="@user.AvatarUrl" alt="当前头像" class="avatar-preview-thumb" style="opacity:0.5;filter:grayscale(1);margin-top:0.2rem;" />
                                    }
                                }
                            </td>

                            <td style="padding:0.8rem 1rem;border-top:1px solid rgba(255,255,255,0.02);">
                                @if (hasUsernameChange) { <span style="color:#8B5CF6;">@user.PendingUsername</span><br /> }
                                @if (hasEmailChange) { <span style="color:#8B5CF6;">@user.PendingEmail</span><br /> }
                                @if (hasAvatarChange)
                                {
                                    <div class="change-item">
                                        <span class="change-label">新头像</span>
                                        <img src="@user.AvatarUrl" alt="新头像预览" class="avatar-preview-thumb" />
                                    </div>
                                }
                            </td>

                            <td style="padding:0.8rem 1rem;border-top:1px solid rgba(255,255,255,0.02);">
                                <button class="btn-action btn-approve" onclick="approveChange(@user.Id)">
                                    ✅ 通过
                                </button>
                                <button class="btn-action btn-reject" onclick="rejectChange(@user.Id)">
                                    ❌ 拒绝
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">✅ 暂无待审核的更改</div>
    }
</div>

<script>
    function approveChange(userId) {
        if (!confirm('确定通过该用户的更改吗？')) return;
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        fetch('/Admin/ApproveUserChange', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': token
            },
            body: `userId=${userId}`
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                location.reload();
            } else {
                alert(data.message);
            }
        });
    }

    function rejectChange(userId) {
        if (!confirm('确定拒绝该用户的更改吗？')) return;
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        fetch('/Admin/RejectUserChange', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': token
            },
            body: `userId=${userId}`
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                location.reload();
            } else {
                alert(data.message);
            }
        });
    }
</script>
