                allowOutsideClick: false,
                showConfirmButton: false,
                background: '#1a1a2e',
                color: '#e0e0e0',
                padding: '2rem',
                width: 380,
            });

            const token = getToken();
            const userIds = selectedUsers.map(u => u.id);

            fetch('/Admin/BatchSendNotification', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
