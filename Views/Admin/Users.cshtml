@model List<MyPersonalWebsite.Models.User>

@{
    ViewData["Title"] = "用户管理";
    var isAdmin = Context.Session.GetInt32("IsAdmin") ?? 0;
    if (isAdmin != 1)
    {
        Context.Response.Redirect("/Auth/Login");
        return;
    }
}

<div style="max-width:1200px;margin:0 auto;padding:2rem 1rem;">
    <h2 style="color:#fff;font-weight:700;margin-bottom:1.5rem;">👥 用户管理</h2>

    <div style="background:rgba(255,255,255,0.02);border-radius:20px;border:1px solid rgba(255,255,255,0.04);overflow:hidden;">
        <table style="width:100%;border-collapse:collapse;color:#e0e0e0;font-size:0.9rem;">
            <thead>
                <tr style="background:rgba(255,255,255,0.02);">
                    <th style="padding:0.8rem 1rem;text-align:left;color:rgba(255,255,255,0.3);">ID</th>
                    <th style="padding:0.8rem 1rem;text-align:left;color:rgba(255,255,255,0.3);">用户名</th>
                    <th style="padding:0.8rem 1rem;text-align:left;color:rgba(255,255,255,0.3);">邮箱</th>
                    <th style="padding:0.8rem 1rem;text-align:left;color:rgba(255,255,255,0.3);">角色</th>
                    <th style="padding:0.8rem 1rem;text-align:left;color:rgba(255,255,255,0.3);">邮箱验证</th>
                    <th style="padding:0.8rem 1rem;text-align:left;color:rgba(255,255,255,0.3);">状态</th>
                    <th style="padding:0.8rem 1rem;text-align:left;color:rgba(255,255,255,0.3);">操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td style="padding:0.8rem 1rem;border-top:1px solid rgba(255,255,255,0.02);">@user.Id</td>
                        <td style="padding:0.8rem 1rem;border-top:1px solid rgba(255,255,255,0.02);">@user.Username</td>
                        <td style="padding:0.8rem 1rem;border-top:1px solid rgba(255,255,255,0.02);">@user.Email</td>
                        <td style="padding:0.8rem 1rem;border-top:1px solid rgba(255,255,255,0.02);">
                            @if (user.IsAdmin)
                            {
                                <span style="color:#8B5CF6;">👑 管理员</span>
                            }
                            else
                            {
                                <span style="color:rgba(255,255,255,0.3);">普通用户</span>
                            }
                        </td>
                        <td style="padding:0.8rem 1rem;border-top:1px solid rgba(255,255,255,0.02);">
                            @if (user.IsEmailVerified)
                            {
                                <span style="color:#28a745;">✅ 已验证</span>
                            }
                            else
                            {
                                <span style="color:#ffc107;">⏳ 未验证</span>
                            }
                        </td>
                        <td style="padding:0.8rem 1rem;border-top:1px solid rgba(255,255,255,0.02);">
                            @if (user.IsBanned)
                            {
                                <span style="color:#dc3545;">🚫 已封禁</span>
                            }
                            else
                            {
                                <span style="color:#28a745;">✅ 正常</span>
                            }
                        </td>
                        <td style="padding:0.8rem 1rem;border-top:1px solid rgba(255,255,255,0.02);">
                            <!-- ⭐ 激活按钮 -->
                            @if (!user.IsEmailVerified)
                            {
                                <button onclick="activateUser(@user.Id)" style="padding:0.2rem 0.8rem;border:none;border-radius:20px;background:rgba(40,167,69,0.12);color:#28a745;cursor:pointer;font-size:0.75rem;margin-right:0.3rem;">
                                    ✅ 激活
                                </button>
                            }

                            @if (!user.IsAdmin)
                            {
                                @if (!user.IsBanned)
                                {
                                    <button onclick="banUser(@user.Id)" style="padding:0.2rem 0.8rem;border:none;border-radius:20px;background:rgba(220,53,69,0.08);color:#dc3545;cursor:pointer;font-size:0.75rem;margin-right:0.3rem;">
                                        🚫 封禁
                                    </button>
                                }
                                else
                                {
                                    <button onclick="unbanUser(@user.Id)" style="padding:0.2rem 0.8rem;border:none;border-radius:20px;background:rgba(40,167,69,0.08);color:#28a745;cursor:pointer;font-size:0.75rem;margin-right:0.3rem;">
                                        ✅ 解封
                                    </button>
                                }
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    function activateUser(userId) {
        if (!confirm('确定激活该用户吗？')) return;
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        fetch('/Admin/ActivateUser', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': token
            },
            body: `userId=${userId}`
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                alert('✅ 用户已激活');
                location.reload();
            } else {
                alert(data.message);
            }
        });
    }

    function banUser(userId) {
        if (!confirm('确定封禁该用户吗？')) return;
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        const hours = prompt('封禁时长（小时），输入0为永久封禁：', '24');
        if (hours === null) return;
        const reason = prompt('封禁原因：', '违反网站规定');
        if (reason === null) return;

        fetch('/Admin/BanUser', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': token
            },
            body: `id=${userId}&hours=${hours}&reason=${encodeURIComponent(reason)}&note=`
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                alert('✅ ' + data.message);
                location.reload();
            } else {
                alert(data.message);
            }
        });
    }

    function unbanUser(userId) {
        if (!confirm('确定解封该用户吗？')) return;
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        fetch('/Admin/UnbanUser', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': token
            },
            body: `id=${userId}`
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                alert('✅ ' + data.message);
                location.reload();
            } else {
                alert(data.message);
            }
        });
    }
</script>
