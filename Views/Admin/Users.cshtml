@model List<MyPersonalWebsite.Models.User>

@{
    ViewData["Title"] = "用户管理";
    var isAdmin = Context.Session.GetInt32("IsAdmin") ?? 0;
    if (isAdmin != 1)
    {
        Context.Response.Redirect("/Auth/Login");
        return;
    }
}

<style>
    .admin-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
    }

    .admin-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid rgba(255,255,255,0.04);
    }

    .admin-header h1 {
        font-size: 1.8rem;
        font-weight: 700;
        background: linear-gradient(135deg, #8B5CF6 0%, #EC4899 50%, #F59E0B 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin: 0;
    }

    .btn-glass {
        padding: 0.5rem 1.5rem;
        border-radius: 40px;
        border: 1px solid rgba(255,255,255,0.06);
        background: rgba(255,255,255,0.04);
        color: rgba(255,255,255,0.7);
        text-decoration: none;
        transition: all 0.3s ease;
        font-size: 0.9rem;
        cursor: pointer;
        display: inline-block;
    }

    .btn-glass:hover {
        background: rgba(255,255,255,0.08);
        color: #fff;
    }

    .btn-glass.primary {
        background: linear-gradient(135deg, #8B5CF6, #EC4899);
        border: none;
        color: #fff;
    }

    .btn-glass.primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 32px rgba(108,60,225,0.2);
    }

    .stats-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .stat-card {
        background: rgba(255,255,255,0.03);
        border-radius: 16px;
        padding: 1rem 1.2rem;
        border: 1px solid rgba(255,255,255,0.04);
        text-align: center;
    }

    .stat-card .number {
        font-size: 1.6rem;
        font-weight: 700;
        color: #fff;
    }

    .stat-card .label {
        font-size: 0.75rem;
        color: rgba(255,255,255,0.4);
        margin-top: 0.2rem;
    }

    .table-wrapper {
        background: rgba(255,255,255,0.02);
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.04);
        overflow-x: auto;
        overflow-y: visible; /* ⭐ 去掉垂直滚动条 */
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.85rem;
        min-width: 1100px; /* ⭐ 宽度调大 */
    }

    th {
        text-align: left;
        padding: 0.8rem 1rem;
        background: rgba(255,255,255,0.03);
        color: rgba(255,255,255,0.4);
        font-weight: 500;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        border-bottom: 1px solid rgba(255,255,255,0.04);
        white-space: nowrap;
    }

    td {
        padding: 0.7rem 1rem;
        border-bottom: 1px solid rgba(255,255,255,0.03);
        color: rgba(255,255,255,0.8);
        vertical-align: middle;
    }

    tr:hover td {
        background: rgba(255,255,255,0.02);
    }

    /* ⭐ 复选框样式 */
    .checkbox-wrapper {
        display: flex;
        align-items: center;
        gap: 0.8rem;
    }

    .checkbox-wrapper input[type="checkbox"] {
        width: 16px;
        height: 16px;
        accent-color: #8B5CF6;
        cursor: pointer;
        flex-shrink: 0;
    }

    .user-cell {
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    .user-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid rgba(255,255,255,0.06);
        flex-shrink: 0;
    }

    .user-avatar-placeholder {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: rgba(255,255,255,0.04);
        color: rgba(255,255,255,0.3);
        font-size: 0.75rem;
        font-weight: 600;
        flex-shrink: 0;
    }

    .badge {
        font-size: 0.65rem;
        padding: 0.15rem 0.7rem;
        border-radius: 20px;
        font-weight: 500;
        display: inline-block;
    }

    .badge-admin {
        background: rgba(139,92,246,0.15);
        color: #8B5CF6;
        border: 1px solid rgba(139,92,246,0.1);
    }

    .badge-user {
        background: rgba(255,255,255,0.04);
        color: rgba(255,255,255,0.4);
        border: 1px solid rgba(255,255,255,0.04);
    }

    .badge-verified {
        background: rgba(40,167,69,0.12);
        color: #28a745;
        border: 1px solid rgba(40,167,69,0.06);
    }

    .badge-unverified {
        background: rgba(255,193,7,0.12);
        color: #ffc107;
        border: 1px solid rgba(255,193,7,0.06);
    }

    .badge-active {
        background: rgba(40,167,69,0.12);
        color: #28a745;
        border: 1px solid rgba(40,167,69,0.06);
    }

    .badge-banned {
        background: rgba(220,53,69,0.12);
        color: #dc3545;
        border: 1px solid rgba(220,53,69,0.06);
    }

    .badge-deleted {
        background: rgba(220,53,69,0.08);
        color: rgba(220,53,69,0.5);
        border: 1px solid rgba(220,53,69,0.04);
    }

    .btn-action {
        padding: 0.2rem 0.7rem;
        border: none;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s ease;
        margin: 0.1rem 0.1rem;
        display: inline-block;
        line-height: 1.5;
    }

    .btn-action.primary {
        background: rgba(79,172,254,0.12);
        color: #4facfe;
    }
    .btn-action.primary:hover {
        background: rgba(79,172,254,0.2);
    }

    .btn-action.success {
        background: rgba(40,167,69,0.12);
        color: #28a745;
    }
    .btn-action.success:hover {
        background: rgba(40,167,69,0.2);
    }

    .btn-action.danger {
        background: rgba(220,53,69,0.08);
        color: #dc3545;
    }
    .btn-action.danger:hover {
        background: rgba(220,53,69,0.15);
    }

    .btn-action.warning {
        background: rgba(255,193,7,0.12);
        color: #ffc107;
    }
    .btn-action.warning:hover {
        background: rgba(255,193,7,0.2);
    }

    .btn-action:disabled {
        opacity: 0.3;
        cursor: not-allowed;
    }

    .empty-state {
        text-align: center;
        padding: 3rem 2rem;
        color: rgba(255,255,255,0.15);
    }

    .filter-bar {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: 1.5rem;
        padding: 1rem 1.5rem;
        background: rgba(255,255,255,0.02);
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.04);
        align-items: center;
    }

    .filter-bar select,
    .filter-bar input {
        padding: 0.4rem 1rem;
        border-radius: 30px;
        border: 1px solid rgba(255,255,255,0.06);
        background: rgba(255,255,255,0.04);
        color: #e0e0e0;
        font-size: 0.85rem;
        outline: none;
    }

    .filter-bar select:focus,
    .filter-bar input:focus {
        border-color: rgba(79,172,254,0.3);
    }

    .filter-bar select option {
        background: #1a1a2e;
        color: #e0e0e0;
    }

    .toast-container {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        z-index: 2000;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        align-items: flex-end;
    }

    .toast-msg {
        padding: 0.8rem 1.8rem;
        border-radius: 40px;
        color: #fff;
        font-weight: 500;
        animation: slideUp 0.4s ease;
        font-size: 0.9rem;
        backdrop-filter: blur(10px);
        background: rgba(0,0,0,0.6);
        border: 1px solid rgba(255,255,255,0.04);
    }

    .toast-msg.success { background: rgba(40,167,69,0.8); }
    .toast-msg.error { background: rgba(220,53,69,0.8); }
    .toast-msg.info { background: rgba(79,172,254,0.8); }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(20px) scale(0.95); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }

    .op-none {
        color: rgba(255,255,255,0.15);
        font-size: 0.75rem;
    }

    /* ⭐ 批量操作栏 */
    .batch-bar {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.8rem 1.5rem;
        background: rgba(108,60,225,0.04);
        border-radius: 16px;
        border: 1px solid rgba(108,60,225,0.06);
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
    }

    .batch-bar .selected-info {
        color: rgba(255,255,255,0.3);
        font-size: 0.85rem;
    }

    .batch-bar .selected-info strong {
        color: #8B5CF6;
    }

    .batch-bar .btn-batch {
        padding: 0.4rem 1.5rem;
        border: none;
        border-radius: 40px;
        background: linear-gradient(135deg, #8B5CF6, #EC4899);
        color: #fff;
        font-weight: 500;
        font-size: 0.85rem;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .batch-bar .btn-batch:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 32px rgba(108,60,225,0.2);
    }

    .batch-bar .btn-batch:disabled {
        opacity: 0.3;
        cursor: not-allowed;
        transform: none;
    }

    .batch-bar .btn-batch.secondary {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.06);
        color: rgba(255,255,255,0.4);
    }

    .batch-bar .btn-batch.secondary:hover {
        background: rgba(255,255,255,0.08);
        box-shadow: none;
        transform: none;
    }

    @@media (max-width: 768px) {
        .admin-header h1 { font-size: 1.3rem; }
        .filter-bar { flex-direction: column; align-items: stretch; }
        .stats-row { grid-template-columns: repeat(2, 1fr); }
        td, th { padding: 0.4rem 0.5rem; font-size: 0.75rem; }
        .batch-bar { flex-direction: column; align-items: stretch; text-align: center; }
    }
</style>

<div class="admin-container">

    <div class="admin-header">
        <h1>👥 用户管理</h1>
        <div>
            <a href="/Admin/Dashboard" class="btn-glass">← 返回后台</a>
        </div>
    </div>

    <!-- 统计 -->
    <div class="stats-row">
        <div class="stat-card">
            <div class="number">@Model.Count(u => !u.IsDeleted)</div>
            <div class="label">👤 活跃用户</div>
        </div>
        <div class="stat-card">
            <div class="number">@Model.Count(u => u.IsBanned && !u.IsDeleted)</div>
            <div class="label">🚫 已封禁</div>
        </div>
        <div class="stat-card">
            <div class="number">@Model.Count(u => !u.IsEmailVerified && !u.IsDeleted)</div>
            <div class="label">⏳ 未验证邮箱</div>
        </div>
        <div class="stat-card">
            <div class="number">@Model.Count(u => u.IsAdmin)</div>
            <div class="label">👑 管理员</div>
        </div>
        <div class="stat-card">
            <div class="number">@Model.Count(u => u.IsDeleted)</div>
            <div class="label">🗑️ 已删除</div>
        </div>
    </div>

    <!-- 筛选 -->
    <div class="filter-bar">
        <span style="color:rgba(255,255,255,0.3);font-size:0.8rem;">🔍 筛选：</span>
        <select id="filterStatus">
            <option value="all">全部</option>
            <option value="active">✅ 正常</option>
            <option value="banned">🚫 已封禁</option>
            <option value="unverified">⏳ 未验证</option>
            <option value="deleted">🗑️ 已删除</option>
            <option value="admin">👑 管理员</option>
        </select>
        <input type="text" id="searchInput" placeholder="搜索用户名或邮箱..." style="flex:1;min-width:160px;" />
        <button class="btn-action primary" onclick="applyFilters()" style="padding:0.3rem 1.2rem;">应用</button>
        <button class="btn-action" onclick="resetFilters()" style="padding:0.3rem 1.2rem;background:rgba(255,255,255,0.04);color:rgba(255,255,255,0.4);">重置</button>
    </div>

    <!-- ⭐ 批量操作栏 -->
    <div class="batch-bar" id="batchBar">
        <div class="checkbox-wrapper">
            <input type="checkbox" id="selectAll" onchange="toggleAllUsers()" />
            <label for="selectAll" style="color:rgba(255,255,255,0.3);font-size:0.85rem;cursor:pointer;">全选</label>
        </div>
        <div class="selected-info">
            已选 <strong id="selectedCount">0</strong> 位用户
        </div>
        <button class="btn-batch" id="batchSendBtn" onclick="batchSendNotification()" disabled>
            📬 批量发送通知
        </button>
        <button class="btn-batch secondary" onclick="clearSelection()">取消选择</button>
    </div>

    <!-- 表格 -->
    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th style="width:40px;">
                        <input type="checkbox" id="selectAllHeader" onchange="toggleAllUsers()" />
                    </th>
                    <th>用户</th>
                    <th>邮箱</th>
                    <th>角色</th>
                    <th>邮箱验证</th>
                    <th>状态</th>
                    <th>注册时间</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    foreach (var user in Model.OrderByDescending(u => u.CreatedAt))
                    {
                        var statusClass = user.IsDeleted ? "badge-deleted" : (user.IsBanned ? "badge-banned" : "badge-active");
                        var statusText = user.IsDeleted ? "🗑️ 已删除" : (user.IsBanned ? "🚫 已封禁" : "✅ 正常");
                        var roleClass = user.IsAdmin ? "badge-admin" : "badge-user";
                        var roleText = user.IsAdmin ? "👑 管理员" : "👤 普通用户";
                        var verifyClass = user.IsEmailVerified ? "badge-verified" : "badge-unverified";
                        var verifyText = user.IsEmailVerified ? "✅ 已验证" : "⏳ 未验证";

                        var avatarUrl = user.AvatarUrl;
                        var isAvatarApproved = user.IsAvatarApproved;
                        var username = user.Username;

                        <tr class="user-row"
                            data-status="@(user.IsDeleted ? "deleted" : (user.IsBanned ? "banned" : (user.IsEmailVerified ? "active" : "unverified")))"
                            data-search="@(user.Username + " " + user.Email)"
                            data-userid="@user.Id">
                            <td>
                                @if (!user.IsAdmin && !user.IsDeleted)
                                {
                                    <input type="checkbox" class="user-checkbox" data-userid="@user.Id" data-username="@user.Username" onchange="updateSelection()" />
                                }
                                else
                                {
                                    <span style="color:rgba(255,255,255,0.1);font-size:0.7rem;">—</span>
                                }
                            </td>
                            <td>
                                <div class="user-cell">
                                    @if (!string.IsNullOrEmpty(avatarUrl) && isAvatarApproved)
                                    {
                                        <img src="@avatarUrl" alt="头像" class="user-avatar" />
                                    }
                                    else if (!string.IsNullOrEmpty(avatarUrl) && !isAvatarApproved)
                                    {
                                        <img src="@avatarUrl" alt="头像" class="user-avatar" style="opacity:0.3;filter:grayscale(1);" />
                                    }
                                    else
                                    {
                                        <span class="user-avatar-placeholder">@(username?.FirstOrDefault().ToString().ToUpper() ?? "?")</span>
                                    }
                                    <strong style="color:#fff;">@user.Username</strong>
                                </div>
                            </td>
                            <td style="color:rgba(255,255,255,0.6);font-size:0.85rem;">@user.Email</td>
                            <td><span class="badge @roleClass">@roleText</span></td>
                            <td><span class="badge @verifyClass">@verifyText</span></td>
                            <td><span class="badge @statusClass">@statusText</span></td>
                            <td style="font-size:0.75rem;color:rgba(255,255,255,0.25);">@user.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                @if (user.IsDeleted)
                                {
                                    <span class="op-none">已删除</span>
                                }
                                else if (user.IsAdmin)
                                {
                                    <span class="op-none">管理员</span>
                                }
                                else
                                {
                                    <div style="display:flex;flex-wrap:wrap;gap:0.2rem;">
                                        @if (!user.IsEmailVerified)
                                        {
                                            <button class="btn-action success" onclick="verifyUser(@user.Id)">✅ 验证</button>
                                        }
                                        @if (!user.IsBanned)
                                        {
                                            <button class="btn-action danger" onclick="banUser(@user.Id)">🚫 封禁</button>
                                        }
                                        else
                                        {
                                            <button class="btn-action success" onclick="unbanUser(@user.Id)">✅ 解封</button>
                                        }
                                        <button class="btn-action danger" onclick="deleteUser(@user.Id)" style="background:rgba(220,53,69,0.04);color:rgba(220,53,69,0.4);">🗑️ 删除</button>
                                        <button class="btn-action primary" onclick="openNotificationModal(@user.Id, '@user.Username')">
                                            📬 通知
                                        </button>
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8">
                            <div class="empty-state">📭 暂无用户</div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>

<!-- Toast -->
<div class="toast-container" id="toastContainer"></div>

@section Scripts {
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // ============================================================
        // 获取 CSRF Token
        // ============================================================
        function getToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        }

        // ============================================================
        // Toast 消息
        // ============================================================
        function showToast(message, type = 'info') {
            Swal.fire({
                text: message,
                icon: type,
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 3000,
                timerProgressBar: true,
                background: '#1a1a2e',
                color: '#e0e0e0',
            });
        }

        // ============================================================
        // ⭐ 多选功能
        // ============================================================
        let selectedUsers = [];

        function updateSelection() {
            const checkboxes = document.querySelectorAll('.user-checkbox:checked');
            selectedUsers = [];
            checkboxes.forEach(cb => {
                selectedUsers.push({
                    id: parseInt(cb.dataset.userid),
                    username: cb.dataset.username
                });
            });

            document.getElementById('selectedCount').textContent = selectedUsers.length;
            document.getElementById('batchSendBtn').disabled = selectedUsers.length === 0;

            // 更新全选状态
            const allCheckboxes = document.querySelectorAll('.user-checkbox');
            const checkedCheckboxes = document.querySelectorAll('.user-checkbox:checked');
            const selectAll = document.getElementById('selectAll');
            const selectAllHeader = document.getElementById('selectAllHeader');
            if (allCheckboxes.length > 0 && checkedCheckboxes.length === allCheckboxes.length) {
                selectAll.checked = true;
                selectAllHeader.checked = true;
            } else {
                selectAll.checked = false;
                selectAllHeader.checked = false;
            }
        }

        function toggleAllUsers() {
            const selectAll = document.getElementById('selectAll');
            const selectAllHeader = document.getElementById('selectAllHeader');
            const isChecked = selectAll.checked;
            selectAllHeader.checked = isChecked;

            document.querySelectorAll('.user-checkbox').forEach(cb => {
                cb.checked = isChecked;
            });
            updateSelection();
        }

        function clearSelection() {
            document.querySelectorAll('.user-checkbox').forEach(cb => cb.checked = false);
            document.getElementById('selectAll').checked = false;
            document.getElementById('selectAllHeader').checked = false;
            updateSelection();
        }

        // ============================================================
        // ⭐ 批量发送通知
        // ============================================================
        function batchSendNotification() {
            if (selectedUsers.length === 0) {
                showToast('请至少选择一位用户', 'error');
                return;
            }

            const userNames = selectedUsers.map(u => u.username).join('、');

            Swal.fire({
                title: `📬 批量发送通知`,
                html: `
                    <div style="text-align:left;padding:0.2rem 0;">
                        <div style="display:flex;align-items:center;gap:0.8rem;padding:0.8rem 1rem;background:rgba(139,92,246,0.04);border-radius:12px;border:1px solid rgba(139,92,246,0.06);margin-bottom:1.2rem;">
                            <div style="font-size:1.5rem;">👥</div>
                            <div>
                                <div style="color:#fff;font-weight:600;font-size:0.95rem;">已选 ${selectedUsers.length} 位用户</div>
                                <div style="color:rgba(255,255,255,0.2);font-size:0.75rem;">${userNames}</div>
                            </div>
                        </div>

                        <div style="margin-bottom:0.8rem;">
                            <label style="display:block;color:rgba(255,255,255,0.4);font-size:0.8rem;font-weight:500;margin-bottom:0.3rem;">📌 标题</label>
                            <input id="batchTitle" class="swal2-input" placeholder="请输入通知标题..." maxlength="50" style="width:100%;padding:0.7rem 1rem;border-radius:12px;border:1px solid rgba(255,255,255,0.06);background:rgba(255,255,255,0.02);color:#fff;font-size:0.9rem;outline:none;">
                            <div style="text-align:right;color:rgba(255,255,255,0.12);font-size:0.7rem;margin-top:0.2rem;"><span id="batchTitleCount">0</span>/50</div>
                        </div>

                        <div style="margin-bottom:0.8rem;">
                            <label style="display:block;color:rgba(255,255,255,0.4);font-size:0.8rem;font-weight:500;margin-bottom:0.3rem;">📝 内容</label>
