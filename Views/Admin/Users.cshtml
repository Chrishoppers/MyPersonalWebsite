@model List<MyPersonalWebsite.Models.User>

@{
    ViewData["Title"] = "用户管理";
    var isAdmin = Context.Session.GetInt32("IsAdmin") ?? 0;
    if (isAdmin != 1)
    {
        Context.Response.Redirect("/Auth/Login");
        return;
    }
}

<style>
    .admin-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
    }

    .admin-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid rgba(255,255,255,0.04);
    }

    .admin-header h1 {
        font-size: 1.8rem;
        font-weight: 700;
        background: linear-gradient(135deg, #8B5CF6 0%, #EC4899 50%, #F59E0B 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin: 0;
    }

    .btn-glass {
        padding: 0.5rem 1.5rem;
        border-radius: 40px;
        border: 1px solid rgba(255,255,255,0.06);
        background: rgba(255,255,255,0.04);
        color: rgba(255,255,255,0.7);
        text-decoration: none;
        transition: all 0.3s ease;
        font-size: 0.9rem;
        cursor: pointer;
        display: inline-block;
    }

    .btn-glass:hover {
        background: rgba(255,255,255,0.08);
        color: #fff;
    }

    .stats-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .stat-card {
        background: rgba(255,255,255,0.03);
        border-radius: 16px;
        padding: 1rem 1.2rem;
        border: 1px solid rgba(255,255,255,0.04);
        text-align: center;
    }

    .stat-card .number {
        font-size: 1.6rem;
        font-weight: 700;
        color: #fff;
    }

    .stat-card .label {
        font-size: 0.75rem;
        color: rgba(255,255,255,0.4);
        margin-top: 0.2rem;
    }

    .table-wrapper {
        background: rgba(255,255,255,0.02);
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.04);
        overflow-x: auto;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.85rem;
        min-width: 1000px;
    }

    th {
        text-align: left;
        padding: 0.8rem 1rem;
        background: rgba(255,255,255,0.03);
        color: rgba(255,255,255,0.4);
        font-weight: 500;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        border-bottom: 1px solid rgba(255,255,255,0.04);
        white-space: nowrap;
    }

    td {
        padding: 0.7rem 1rem;
        border-bottom: 1px solid rgba(255,255,255,0.03);
        color: rgba(255,255,255,0.8);
        vertical-align: middle;
    }

    tr:hover td {
        background: rgba(255,255,255,0.02);
    }

    .user-cell {
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    .user-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid rgba(255,255,255,0.06);
        flex-shrink: 0;
    }

    .user-avatar-placeholder {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: rgba(255,255,255,0.04);
        color: rgba(255,255,255,0.3);
        font-size: 0.75rem;
        font-weight: 600;
        flex-shrink: 0;
    }

    .badge {
        font-size: 0.65rem;
        padding: 0.15rem 0.7rem;
        border-radius: 20px;
        font-weight: 500;
        display: inline-block;
    }

    .badge-admin {
        background: rgba(139,92,246,0.15);
        color: #8B5CF6;
        border: 1px solid rgba(139,92,246,0.1);
    }

    .badge-user {
        background: rgba(255,255,255,0.04);
        color: rgba(255,255,255,0.4);
        border: 1px solid rgba(255,255,255,0.04);
    }

    .badge-verified {
        background: rgba(40,167,69,0.12);
        color: #28a745;
        border: 1px solid rgba(40,167,69,0.06);
    }

    .badge-unverified {
        background: rgba(255,193,7,0.12);
        color: #ffc107;
        border: 1px solid rgba(255,193,7,0.06);
    }

    .badge-active {
        background: rgba(40,167,69,0.12);
        color: #28a745;
        border: 1px solid rgba(40,167,69,0.06);
    }

    .badge-banned {
        background: rgba(220,53,69,0.12);
        color: #dc3545;
        border: 1px solid rgba(220,53,69,0.06);
    }

    .badge-deleted {
        background: rgba(220,53,69,0.08);
        color: rgba(220,53,69,0.5);
        border: 1px solid rgba(220,53,69,0.04);
    }

    .btn-action {
        padding: 0.2rem 0.7rem;
        border: none;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s ease;
        margin: 0.1rem 0.1rem;
        display: inline-block;
        line-height: 1.5;
    }

    .btn-action.primary {
        background: rgba(79,172,254,0.12);
        color: #4facfe;
    }
    .btn-action.primary:hover {
        background: rgba(79,172,254,0.2);
    }

    .btn-action.success {
        background: rgba(40,167,69,0.12);
        color: #28a745;
    }
    .btn-action.success:hover {
        background: rgba(40,167,69,0.2);
    }

    .btn-action.danger {
        background: rgba(220,53,69,0.08);
        color: #dc3545;
    }
    .btn-action.danger:hover {
        background: rgba(220,53,69,0.15);
    }

    .btn-action.warning {
        background: rgba(255,193,7,0.12);
        color: #ffc107;
    }
    .btn-action.warning:hover {
        background: rgba(255,193,7,0.2);
    }

    .btn-action:disabled {
        opacity: 0.3;
        cursor: not-allowed;
    }

    .empty-state {
        text-align: center;
        padding: 3rem 2rem;
        color: rgba(255,255,255,0.15);
    }

    .filter-bar {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: 1.5rem;
        padding: 1rem 1.5rem;
        background: rgba(255,255,255,0.02);
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.04);
        align-items: center;
    }

    .filter-bar select,
    .filter-bar input {
        padding: 0.4rem 1rem;
        border-radius: 30px;
        border: 1px solid rgba(255,255,255,0.06);
        background: rgba(255,255,255,0.04);
        color: #e0e0e0;
        font-size: 0.85rem;
        outline: none;
    }

    .filter-bar select:focus,
    .filter-bar input:focus {
        border-color: rgba(79,172,254,0.3);
    }

    .filter-bar select option {
        background: #1a1a2e;
        color: #e0e0e0;
    }

    .toast-container {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        z-index: 2000;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        align-items: flex-end;
    }

    .toast-msg {
        padding: 0.8rem 1.8rem;
        border-radius: 40px;
        color: #fff;
        font-weight: 500;
        animation: slideUp 0.4s ease;
        font-size: 0.9rem;
        backdrop-filter: blur(10px);
        background: rgba(0,0,0,0.6);
        border: 1px solid rgba(255,255,255,0.04);
    }

    .toast-msg.success { background: rgba(40,167,69,0.8); }
    .toast-msg.error { background: rgba(220,53,69,0.8); }
    .toast-msg.info { background: rgba(79,172,254,0.8); }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(20px) scale(0.95); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }

    .op-none {
        color: rgba(255,255,255,0.15);
        font-size: 0.75rem;
    }

    @@media (max-width: 768px) {
        .admin-header h1 { font-size: 1.3rem; }
        .filter-bar { flex-direction: column; align-items: stretch; }
        .stats-row { grid-template-columns: repeat(2, 1fr); }
        td, th { padding: 0.4rem 0.5rem; font-size: 0.75rem; }
    }
</style>

<div class="admin-container">

    <div class="admin-header">
        <h1>👥 用户管理</h1>
        <div>
            <a href="/Admin/Dashboard" class="btn-glass">← 返回后台</a>
        </div>
    </div>

    <!-- 统计 -->
    <div class="stats-row">
        <div class="stat-card">
            <div class="number">@Model.Count(u => !u.IsDeleted)</div>
            <div class="label">👤 活跃用户</div>
        </div>
        <div class="stat-card">
            <div class="number">@Model.Count(u => u.IsBanned && !u.IsDeleted)</div>
            <div class="label">🚫 已封禁</div>
        </div>
        <div class="stat-card">
            <div class="number">@Model.Count(u => !u.IsEmailVerified && !u.IsDeleted)</div>
            <div class="label">⏳ 未验证邮箱</div>
        </div>
        <div class="stat-card">
            <div class="number">@Model.Count(u => u.IsAdmin)</div>
            <div class="label">👑 管理员</div>
        </div>
        <div class="stat-card">
            <div class="number">@Model.Count(u => u.IsDeleted)</div>
            <div class="label">🗑️ 已删除</div>
        </div>
    </div>

    <!-- 筛选 -->
    <div class="filter-bar">
        <span style="color:rgba(255,255,255,0.3);font-size:0.8rem;">🔍 筛选：</span>
        <select id="filterStatus">
            <option value="all">全部</option>
            <option value="active">✅ 正常</option>
            <option value="banned">🚫 已封禁</option>
            <option value="unverified">⏳ 未验证</option>
            <option value="deleted">🗑️ 已删除</option>
            <option value="admin">👑 管理员</option>
        </select>
        <input type="text" id="searchInput" placeholder="搜索用户名或邮箱..." style="flex:1;min-width:160px;" />
        <button class="btn-action primary" onclick="applyFilters()" style="padding:0.3rem 1.2rem;">应用</button>
        <button class="btn-action" onclick="resetFilters()" style="padding:0.3rem 1.2rem;background:rgba(255,255,255,0.04);color:rgba(255,255,255,0.4);">重置</button>
    </div>

    <!-- 表格 -->
    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>用户</th>
                    <th>邮箱</th>
                    <th>角色</th>
                    <th>邮箱验证</th>
                    <th>状态</th>
                    <th>注册时间</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    foreach (var user in Model.OrderByDescending(u => u.CreatedAt))
                    {
                        var statusClass = user.IsDeleted ? "badge-deleted" : (user.IsBanned ? "badge-banned" : "badge-active");
                        var statusText = user.IsDeleted ? "🗑️ 已删除" : (user.IsBanned ? "🚫 已封禁" : "✅ 正常");
                        var roleClass = user.IsAdmin ? "badge-admin" : "badge-user";
                        var roleText = user.IsAdmin ? "👑 管理员" : "👤 普通用户";
                        var verifyClass = user.IsEmailVerified ? "badge-verified" : "badge-unverified";
                        var verifyText = user.IsEmailVerified ? "✅ 已验证" : "⏳ 未验证";

                        var avatarUrl = user.AvatarUrl;
                        var isAvatarApproved = user.IsAvatarApproved;
                        var username = user.Username;

                        <tr class="user-row"
                            data-status="@(user.IsDeleted ? "deleted" : (user.IsBanned ? "banned" : (user.IsEmailVerified ? "active" : "unverified")))"
                            data-search="@(user.Username + " " + user.Email)">
                            <td>
                                <div class="user-cell">
                                    @if (!string.IsNullOrEmpty(avatarUrl) && isAvatarApproved)
                                    {
                                        <img src="@avatarUrl" alt="头像" class="user-avatar" />
                                    }
                                    else if (!string.IsNullOrEmpty(avatarUrl) && !isAvatarApproved)
                                    {
                                        <img src="@avatarUrl" alt="头像" class="user-avatar" style="opacity:0.3;filter:grayscale(1);" />
                                    }
                                    else
                                    {
                                        <span class="user-avatar-placeholder">@(username?.FirstOrDefault().ToString().ToUpper() ?? "?")</span>
                                    }
                                    <strong style="color:#fff;">@user.Username</strong>
                                </div>
                            </td>
                            <td style="color:rgba(255,255,255,0.6);font-size:0.85rem;">@user.Email</td>
                            <td><span class="badge @roleClass">@roleText</span></td>
                            <td><span class="badge @verifyClass">@verifyText</span></td>
                            <td><span class="badge @statusClass">@statusText</span></td>
                            <td style="font-size:0.75rem;color:rgba(255,255,255,0.25);">@user.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                @if (user.IsDeleted)
                                {
                                    <span class="op-none">已删除，无操作</span>
                                }
                                else if (user.IsAdmin)
                                {
                                    <span class="op-none">管理员不可操作</span>
                                }
                                else
                                {
                                    <div style="display:flex;flex-wrap:wrap;gap:0.2rem;">
                                        @if (!user.IsEmailVerified)
                                        {
                                            <button class="btn-action success" onclick="verifyUser(@user.Id)">✅ 验证</button>
                                        }
                                        @if (!user.IsBanned)
                                        {
                                            <button class="btn-action danger" onclick="banUser(@user.Id)">🚫 封禁</button>
                                        }
                                        else
                                        {
                                            <button class="btn-action success" onclick="unbanUser(@user.Id)">✅ 解封</button>
                                        }
                                        <button class="btn-action danger" onclick="deleteUser(@user.Id)" style="background:rgba(220,53,69,0.04);color:rgba(220,53,69,0.4);">🗑️ 删除</button>
                                        <!-- ⭐ 发送通知按钮 -->
                                        <button class="btn-action primary" onclick="openNotificationModal(@user.Id, '@user.Username')">
                                            📬 通知
                                        </button>
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">📭 暂无用户</div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>

@section Scripts {
    <!-- ⭐ 引入 SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // ============================================================
        // 获取 CSRF Token
        // ============================================================
        function getToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        }

        // ============================================================
        // Toast 消息
        // ============================================================
        function showToast(message, type = 'info') {
            Swal.fire({
                text: message,
                icon: type,
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 3000,
                timerProgressBar: true,
                background: '#1a1a2e',
                color: '#e0e0e0',
            });
        }

        // ============================================================
        // ⭐ 发送通知弹窗（漂亮弹窗）
        // ============================================================
        // ⭐ 发送通知弹窗（高颜值版）
function openNotificationModal(userId, username) {
    Swal.fire({
        title: `<span style="font-size:1.6rem;">📬 发送通知</span>`,
        html: `
            <div style="text-align:left;padding:0.5rem 0;">
                <!-- 用户信息 -->
                <div style="display:flex;align-items:center;gap:0.8rem;padding:0.8rem 1rem;background:rgba(139,92,246,0.04);border-radius:12px;border:1px solid rgba(139,92,246,0.06);margin-bottom:1.2rem;">
                    <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#8B5CF6,#EC4899);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:0.9rem;flex-shrink:0;">${username.charAt(0).toUpperCase()}</div>
                    <div>
                        <div style="color:#fff;font-weight:600;font-size:0.95rem;">${username}</div>
                        <div style="color:rgba(255,255,255,0.2);font-size:0.75rem;">将收到邮件+站内通知</div>
                    </div>
                </div>

                <!-- 标题 -->
                <div style="margin-bottom:0.8rem;">
                    <label style="display:block;color:rgba(255,255,255,0.4);font-size:0.8rem;font-weight:500;margin-bottom:0.3rem;">📌 标题</label>
                    <input id="notifyTitle" class="swal2-input" placeholder="输入通知标题..." maxlength="50" style="width:100%;padding:0.7rem 1rem;border-radius:12px;border:1px solid rgba(255,255,255,0.06);background:rgba(255,255,255,0.02);color:#fff;font-size:0.9rem;outline:none;transition:border-color 0.3s;">
                    <div style="text-align:right;color:rgba(255,255,255,0.12);font-size:0.7rem;margin-top:0.2rem;"><span id="titleCount">0</span>/50</div>
                </div>

                <!-- 内容 -->
                <div style="margin-bottom:0.8rem;">
                    <label style="display:block;color:rgba(255,255,255,0.4);font-size:0.8rem;font-weight:500;margin-bottom:0.3rem;">📝 内容</label>
                    <textarea id="notifyMessage" class="swal2-textarea" placeholder="输入通知内容..." maxlength="500" style="width:100%;padding:0.7rem 1rem;border-radius:12px;border:1px solid rgba(255,255,255,0.06);background:rgba(255,255,255,0.02);color:#fff;font-size:0.9rem;outline:none;resize:vertical;min-height:100px;font-family:inherit;transition:border-color 0.3s;"></textarea>
                    <div style="text-align:right;color:rgba(255,255,255,0.12);font-size:0.7rem;margin-top:0.2rem;"><span id="messageCount">0</span>/500</div>
                </div>

                <!-- 类型选择 -->
                <div>
                    <label style="display:block;color:rgba(255,255,255,0.4);font-size:0.8rem;font-weight:500;margin-bottom:0.3rem;">🔖 通知类型</label>
                    <div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:0.4rem;">
                        <div class="type-option" data-type="info" onclick="selectType('info')" style="padding:0.4rem 0.2rem;text-align:center;border-radius:8px;border:2px solid rgba(255,255,255,0.04);background:rgba(255,255,255,0.02);color:rgba(255,255,255,0.3);font-size:0.7rem;cursor:pointer;transition:all 0.3s ease;">ℹ️ 信息</div>
                        <div class="type-option" data-type="success" onclick="selectType('success')" style="padding:0.4rem 0.2rem;text-align:center;border-radius:8px;border:2px solid rgba(255,255,255,0.04);background:rgba(255,255,255,0.02);color:rgba(255,255,255,0.3);font-size:0.7rem;cursor:pointer;transition:all 0.3s ease;">✅ 成功</div>
                        <div class="type-option" data-type="warning" onclick="selectType('warning')" style="padding:0.4rem 0.2rem;text-align:center;border-radius:8px;border:2px solid rgba(255,255,255,0.04);background:rgba(255,255,255,0.02);color:rgba(255,255,255,0.3);font-size:0.7rem;cursor:pointer;transition:all 0.3s ease;">⚠️ 警告</div>
                        <div class="type-option" data-type="danger" onclick="selectType('danger')" style="padding:0.4rem 0.2rem;text-align:center;border-radius:8px;border:2px solid rgba(255,255,255,0.04);background:rgba(255,255,255,0.02);color:rgba(255,255,255,0.3);font-size:0.7rem;cursor:pointer;transition:all 0.3s ease;">🔥 重要</div>
                    </div>
                    <input type="hidden" id="notifyType" value="info" />
                </div>
            </div>
        `,
        confirmButtonText: '📤 发送通知',
        cancelButtonText: '取消',
        showCancelButton: true,
        background: '#1a1a2e',
        color: '#e0e0e0',
        confirmButtonColor: '#8B5CF6',
        cancelButtonColor: '#2a2a3e',
        focusConfirm: false,
        width: 520,
        padding: '2rem',
        preConfirm: () => {
            const title = document.getElementById('notifyTitle').value.trim();
            const message = document.getElementById('notifyMessage').value.trim();
            const type = document.getElementById('notifyType').value;

            if (!title) {
                Swal.showValidationMessage('请输入标题');
                return false;
            }
            if (!message) {
                Swal.showValidationMessage('请输入内容');
                return false;
            }
            return { userId, title, message, type };
        }
    }).then((result) => {
        if (result.isConfirmed && result.value) {
            const { userId, title, message, type } = result.value;
            sendNotification(userId, title, message, type);
        }
    });

    // 字数统计
    setTimeout(() => {
        const titleInput = document.getElementById('notifyTitle');
        const msgInput = document.getElementById('notifyMessage');
        const titleCount = document.getElementById('titleCount');
        const msgCount = document.getElementById('messageCount');

        if (titleInput) {
            titleInput.addEventListener('input', function() {
                titleCount.textContent = this.value.length;
                this.style.borderColor = this.value.length > 45 ? 'rgba(220,53,69,0.2)' : 'rgba(255,255,255,0.06)';
            });
        }
        if (msgInput) {
            msgInput.addEventListener('input', function() {
                msgCount.textContent = this.value.length;
                this.style.borderColor = this.value.length > 450 ? 'rgba(220,53,69,0.2)' : 'rgba(255,255,255,0.06)';
            });
        }
    }, 100);
}

// ⭐ 选择类型
function selectType(type) {
    document.getElementById('notifyType').value = type;
    document.querySelectorAll('.type-option').forEach(el => {
        el.style.borderColor = 'rgba(255,255,255,0.04)';
        el.style.background = 'rgba(255,255,255,0.02)';
        el.style.color = 'rgba(255,255,255,0.3)';
    });
    const selected = document.querySelector(`.type-option[data-type="${type}"]`);
    const colors = {
        'info': '#4facfe',
        'success': '#28a745',
        'warning': '#ffc107',
        'danger': '#dc3545'
    };
    selected.style.borderColor = colors[type];
    selected.style.background = `${colors[type]}22`;
    selected.style.color = colors[type];
}

        // ============================================================
        // 发送通知 API
        // ============================================================
        function sendNotification(userId, title, message, type) {
            Swal.fire({
                title: '⏳ 发送中...',
                text: '请稍候',
                allowOutsideClick: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            const token = getToken();
            fetch('/Admin/SendNotification', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: `userId=${userId}&title=${encodeURIComponent(title)}&message=${encodeURIComponent(message)}&type=${encodeURIComponent(type)}`
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    Swal.fire({
                        title: '✅ 发送成功！',
                        text: data.message,
                        icon: 'success',
                        background: '#1a1a2e',
                        color: '#e0e0e0',
                        confirmButtonColor: '#8B5CF6',
                        timer: 2000,
                        timerProgressBar: true
                    });
                } else {
                    Swal.fire({
                        title: '❌ 发送失败',
                        text: data.message,
                        icon: 'error',
                        background: '#1a1a2e',
                        color: '#e0e0e0',
                        confirmButtonColor: '#8B5CF6'
                    });
                }
            })
            .catch(() => {
                Swal.fire({
                    title: '❌ 发送失败',
                    text: '网络错误，请重试',
                    icon: 'error',
                    background: '#1a1a2e',
                    color: '#e0e0e0',
                    confirmButtonColor: '#8B5CF6'
                });
            });
        }

        // ============================================================
        // 验证用户
        // ============================================================
        function verifyUser(userId) {
            Swal.fire({
                title: '确认操作',
                text: '确认通过该用户的邮箱验证吗？',
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: '✅ 确认验证',
                cancelButtonText: '取消',
                background: '#1a1a2e',
                color: '#e0e0e0',
                confirmButtonColor: '#28a745',
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch('/Admin/ActivateUser', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': getToken()
                        },
                        body: `userId=${userId}`
                    })
                    .then(r => r.json())
                    .then(data => {
                        if (data.success) {
                            showToast('✅ 邮箱验证已通过', 'success');
                            setTimeout(() => location.reload(), 800);
                        } else {
                            showToast(data.message || '操作失败', 'error');
                        }
                    })
                    .catch(() => showToast('操作失败，请重试', 'error'));
                }
            });
        }

        // ============================================================
        // 封禁用户
        // ============================================================
        function banUser(userId) {
            Swal.fire({
                title: '🚫 封禁用户',
                html: `
                    <div style="text-align:left;">
                        <div style="margin-bottom:0.8rem;">
                            <label style="display:block;color:rgba(255,255,255,0.4);font-size:0.8rem;margin-bottom:0.3rem;">⏰ 封禁时长（小时）</label>
                            <input id="banHours" class="swal2-input" placeholder="输入0为永久封禁" value="24" style="width:100%;padding:0.6rem 1rem;border-radius:12px;border:1px solid rgba(255,255,255,0.06);background:rgba(255,255,255,0.02);color:#fff;font-size:0.9rem;outline:none;">
                        </div>
                        <div>
                            <label style="display:block;color:rgba(255,255,255,0.4);font-size:0.8rem;margin-bottom:0.3rem;">📌 原因</label>
                            <input id="banReason" class="swal2-input" placeholder="请输入封禁原因" value="违反网站规定" style="width:100%;padding:0.6rem 1rem;border-radius:12px;border:1px solid rgba(255,255,255,0.06);background:rgba(255,255,255,0.02);color:#fff;font-size:0.9rem;outline:none;">
                        </div>
                    </div>
                `,
                confirmButtonText: '🚫 确认封禁',
                cancelButtonText: '取消',
                showCancelButton: true,
                focusConfirm: false,
                preConfirm: () => {
                    const hours = document.getElementById('banHours').value;
                    const reason = document.getElementById('banReason').value.trim();
                    if (!hours) {
                        Swal.showValidationMessage('请输入封禁时长');
                        return false;
                    }
                    if (!reason) {
                        Swal.showValidationMessage('请输入封禁原因');
                        return false;
                    }
                    return { hours, reason };
                }
            }).then((result) => {
                if (result.isConfirmed && result.value) {
                    const { hours, reason } = result.value;
                    fetch('/Admin/BanUser', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': getToken()
                        },
                        body: `id=${userId}&hours=${hours}&reason=${encodeURIComponent(reason)}&note=`
                    })
                    .then(r => r.json())
                    .then(data => {
                        if (data.success) {
                            showToast('✅ ' + data.message, 'success');
                            setTimeout(() => location.reload(), 800);
                        } else {
                            showToast(data.message || '操作失败', 'error');
                        }
                    })
                    .catch(() => showToast('操作失败，请重试', 'error'));
                }
            });
        }

