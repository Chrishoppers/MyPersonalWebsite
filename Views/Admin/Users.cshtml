@model List<MyPersonalWebsite.Models.User>

@{
    ViewData["Title"] = "用户管理";
    var isAdmin = Context.Session.GetInt32("IsAdmin") ?? 0;
    if (isAdmin != 1)
    {
        Context.Response.Redirect("/Auth/Login");
        return;
    }
}

<style>
    .admin-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
    }

    .admin-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid rgba(255,255,255,0.04);
    }

    .admin-header h1 {
        font-size: 1.8rem;
        font-weight: 700;
        background: linear-gradient(135deg, #8B5CF6 0%, #EC4899 50%, #F59E0B 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin: 0;
    }

    .stats-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .stat-card {
        background: rgba(255,255,255,0.03);
        border-radius: 16px;
        padding: 1rem 1.2rem;
        border: 1px solid rgba(255,255,255,0.04);
        text-align: center;
    }

    .stat-card .number {
        font-size: 1.6rem;
        font-weight: 700;
        color: #fff;
    }

    .stat-card .label {
        font-size: 0.75rem;
        color: rgba(255,255,255,0.4);
        margin-top: 0.2rem;
    }

    .table-wrapper {
        background: rgba(255,255,255,0.02);
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.04);
        overflow-x: auto;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.85rem;
        min-width: 900px;
    }

    th {
        text-align: left;
        padding: 0.8rem 1rem;
        background: rgba(255,255,255,0.03);
        color: rgba(255,255,255,0.4);
        font-weight: 500;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        border-bottom: 1px solid rgba(255,255,255,0.04);
        white-space: nowrap;
    }

    td {
        padding: 0.7rem 1rem;
        border-bottom: 1px solid rgba(255,255,255,0.03);
        color: rgba(255,255,255,0.8);
        vertical-align: middle;
    }

    tr:hover td {
        background: rgba(255,255,255,0.02);
    }

    .badge {
        font-size: 0.65rem;
        padding: 0.15rem 0.7rem;
        border-radius: 20px;
        font-weight: 500;
        display: inline-block;
    }

    .badge-admin {
        background: rgba(139,92,246,0.15);
        color: #8B5CF6;
        border: 1px solid rgba(139,92,246,0.1);
    }

    .badge-user {
        background: rgba(255,255,255,0.04);
        color: rgba(255,255,255,0.4);
        border: 1px solid rgba(255,255,255,0.04);
    }

    .badge-verified {
        background: rgba(40,167,69,0.12);
        color: #28a745;
        border: 1px solid rgba(40,167,69,0.06);
    }

    .badge-unverified {
        background: rgba(255,193,7,0.12);
        color: #ffc107;
        border: 1px solid rgba(255,193,7,0.06);
    }

    .badge-active {
        background: rgba(40,167,69,0.12);
        color: #28a745;
        border: 1px solid rgba(40,167,69,0.06);
    }

    .badge-banned {
        background: rgba(220,53,69,0.12);
        color: #dc3545;
        border: 1px solid rgba(220,53,69,0.06);
    }

    .badge-deleted {
        background: rgba(220,53,69,0.08);
        color: rgba(220,53,69,0.5);
        border: 1px solid rgba(220,53,69,0.04);
    }

    .btn-action {
        padding: 0.2rem 0.7rem;
        border: none;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s ease;
        margin: 0.1rem 0.1rem;
    }

    .btn-action.primary {
        background: rgba(79,172,254,0.12);
        color: #4facfe;
    }
    .btn-action.primary:hover {
        background: rgba(79,172,254,0.2);
    }

    .btn-action.success {
        background: rgba(40,167,69,0.12);
        color: #28a745;
    }
    .btn-action.success:hover {
        background: rgba(40,167,69,0.2);
    }

    .btn-action.danger {
        background: rgba(220,53,69,0.08);
        color: #dc3545;
    }
    .btn-action.danger:hover {
        background: rgba(220,53,69,0.15);
    }

    .btn-action.warning {
        background: rgba(255,193,7,0.12);
        color: #ffc107;
    }
    .btn-action.warning:hover {
        background: rgba(255,193,7,0.2);
    }

    .btn-action:disabled {
        opacity: 0.4;
        cursor: not-allowed;
    }

    .empty-state {
        text-align: center;
        padding: 3rem 2rem;
        color: rgba(255,255,255,0.15);
    }

    .filter-bar {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: 1.5rem;
        padding: 1rem 1.5rem;
        background: rgba(255,255,255,0.02);
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.04);
        align-items: center;
    }

    .filter-bar select,
    .filter-bar input {
        padding: 0.4rem 1rem;
        border-radius: 30px;
        border: 1px solid rgba(255,255,255,0.06);
        background: rgba(255,255,255,0.04);
        color: #e0e0e0;
        font-size: 0.85rem;
        outline: none;
    }

    .filter-bar select:focus,
    .filter-bar input:focus {
        border-color: rgba(79,172,254,0.3);
    }

    .filter-bar select option {
        background: #1a1a2e;
        color: #e0e0e0;
    }

    .toast-container {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        z-index: 2000;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        align-items: flex-end;
    }

    .toast-msg {
        padding: 0.8rem 1.8rem;
        border-radius: 40px;
        color: #fff;
        font-weight: 500;
        animation: slideUp 0.4s ease;
        font-size: 0.9rem;
        backdrop-filter: blur(10px);
        background: rgba(0,0,0,0.6);
        border: 1px solid rgba(255,255,255,0.04);
    }

    .toast-msg.success { background: rgba(40,167,69,0.8); }
    .toast-msg.error { background: rgba(220,53,69,0.8); }
    .toast-msg.info { background: rgba(79,172,254,0.8); }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(20px) scale(0.95); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }

    @@media (max-width: 768px) {
        .admin-header h1 { font-size: 1.3rem; }
        .filter-bar { flex-direction: column; align-items: stretch; }
        .stats-row { grid-template-columns: repeat(2, 1fr); }
        td, th { padding: 0.4rem 0.5rem; font-size: 0.75rem; }
    }
</style>

<div class="admin-container">

    <div class="admin-header">
        <h1>👥 用户管理</h1>
        <div>
            <a href="/Admin/Dashboard" class="btn-action primary" style="padding:0.4rem 1.2rem;text-decoration:none;">
                ← 返回后台
            </a>
        </div>
    </div>

    <!-- 统计 -->
    <div class="stats-row">
        <div class="stat-card">
            <div class="number">@Model.Count(u => !u.IsDeleted)</div>
            <div class="label">👤 活跃用户</div>
        </div>
        <div class="stat-card">
            <div class="number">@Model.Count(u => u.IsBanned && !u.IsDeleted)</div>
            <div class="label">🚫 已封禁</div>
        </div>
        <div class="stat-card">
            <div class="number">@Model.Count(u => !u.IsEmailVerified && !u.IsDeleted)</div>
            <div class="label">⏳ 未验证邮箱</div>
        </div>
        <div class="stat-card">
            <div class="number">@Model.Count(u => u.IsAdmin)</div>
            <div class="label">👑 管理员</div>
        </div>
        <div class="stat-card">
            <div class="number">@Model.Count(u => u.IsDeleted)</div>
            <div class="label">🗑️ 已删除</div>
        </div>
    </div>

    <!-- 筛选 -->
    <div class="filter-bar">
        <span style="color:rgba(255,255,255,0.3);font-size:0.8rem;">🔍 筛选：</span>
        <select id="filterStatus">
            <option value="all">全部</option>
            <option value="active">✅ 正常</option>
            <option value="banned">🚫 已封禁</option>
            <option value="unverified">⏳ 未验证</option>
            <option value="deleted">🗑️ 已删除</option>
            <option value="admin">👑 管理员</option>
        </select>
        <input type="text" id="searchInput" placeholder="搜索用户名或邮箱..." style="flex:1;min-width:160px;" />
        <button class="btn-action primary" onclick="applyFilters()" style="padding:0.3rem 1.2rem;">应用</button>
        <button class="btn-action" onclick="resetFilters()" style="padding:0.3rem 1.2rem;background:rgba(255,255,255,0.04);color:rgba(255,255,255,0.4);">重置</button>
    </div>

    <!-- 表格 -->
    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>用户名</th>
                    <th>邮箱</th>
                    <th>角色</th>
                    <th>邮箱验证</th>
                    <th>状态</th>
                    <th>注册时间</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    foreach (var user in Model.OrderByDescending(u => u.CreatedAt))
                    {
                        var statusClass = user.IsDeleted ? "badge-deleted" : (user.IsBanned ? "badge-banned" : "badge-active");
                        var statusText = user.IsDeleted ? "🗑️ 已删除" : (user.IsBanned ? "🚫 已封禁" : "✅ 正常");
                        var roleClass = user.IsAdmin ? "badge-admin" : "badge-user";
                        var roleText = user.IsAdmin ? "👑 管理员" : "👤 普通用户";
                        var verifyClass = user.IsEmailVerified ? "badge-verified" : "badge-unverified";
                        var verifyText = user.IsEmailVerified ? "✅ 已验证" : "⏳ 未验证";

                        <tr class="user-row"
                            data-status="@(user.IsDeleted ? "deleted" : (user.IsBanned ? "banned" : (user.IsEmailVerified ? "active" : "unverified")))"
                            data-search="@(user.Username + " " + user.Email)">
                            <td><span style="color:rgba(255,255,255,0.3);font-size:0.8rem;">#@user.Id</span></td>
                            <td><strong style="color:#fff;">@user.Username</strong></td>
                            <td style="color:rgba(255,255,255,0.6);font-size:0.85rem;">@user.Email</td>
                            <td><span class="badge @roleClass">@roleText</span></td>
                            <td><span class="badge @verifyClass">@verifyText</span></td>
                            <td><span class="badge @statusClass">@statusText</span></td>
                            <td style="font-size:0.75rem;color:rgba(255,255,255,0.25);">@user.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                <div style="display:flex;flex-wrap:wrap;gap:0.2rem;">

                                    @if (!user.IsAdmin)
                                    {
                                        @if (!user.IsEmailVerified)
                                        {
                                            <button class="btn-action success" onclick="verifyUser(@user.Id)">
                                                ✅ 验证
                                            </button>
                                        }

                                        @if (!user.IsBanned && !user.IsDeleted)
                                        {
                                            <button class="btn-action danger" onclick="banUser(@user.Id)">
                                                🚫 封禁
                                            </button>
                                        }
                                        else if (user.IsBanned && !user.IsDeleted)
                                        {
                                            <button class="btn-action success" onclick="unbanUser(@user.Id)">
                                                ✅ 解封
                                            </button>
                                        }

                                        @if (!user.IsDeleted)
                                        {
                                            <button class="btn-action danger" onclick="deleteUser(@user.Id)" style="background:rgba(220,53,69,0.04);color:rgba(220,53,69,0.4);">
                                                🗑️ 删除
                                            </button>
                                        }
                                    }
                                    else
                                    {
                                        <span style="color:rgba(255,255,255,0.15);font-size:0.7rem;">不可操作</span>
                                    }

                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8">
                            <div class="empty-state">📭 暂无用户</div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>

<!-- Toast -->
<div class="toast-container" id="toastContainer"></div>

@section Scripts {
    <script>
        // ============================================================
        // 获取 CSRF Token
        // ============================================================
        function getToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        }

        // ============================================================
        // Toast 消息
        // ============================================================
        function showToast(message, type = 'info') {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast-msg ${type}`;
            toast.textContent = message;
            container.appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(20px)';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        // ============================================================
        // 1. 通过邮箱验证
        // ============================================================
        function verifyUser(userId) {
            if (!confirm('确认通过该用户的邮箱验证吗？')) return;

            fetch('/Admin/ActivateUser', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': getToken()
                },
                body: `userId=${userId}`
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    showToast('✅ 邮箱验证已通过', 'success');
                    setTimeout(() => location.reload(), 800);
                } else {
                    showToast(data.message || '操作失败', 'error');
                }
            })
            .catch(() => showToast('操作失败，请重试', 'error'));
        }

        // ============================================================
        // 2. 封禁用户
        // ============================================================
        function banUser(userId) {
            const hours = prompt('封禁时长（小时），输入0为永久封禁：', '24');
            if (hours === null) return;

            const reason = prompt('封禁原因：', '违反网站规定');
            if (reason === null) return;

            if (!confirm(`确认封禁该用户 ${hours} 小时吗？`)) return;

            fetch('/Admin/BanUser', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': getToken()
                },
                body: `id=${userId}&hours=${hours}&reason=${encodeURIComponent(reason)}&note=`
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    showToast('✅ ' + data.message, 'success');
                    setTimeout(() => location.reload(), 800);
                } else {
                    showToast(data.message || '操作失败', 'error');
                }
            })
            .catch(() => showToast('操作失败，请重试', 'error'));
        }

        // ============================================================
        // 3. 解封用户
        // ============================================================
        function unbanUser(userId) {
            if (!confirm('确认解封该用户吗？')) return;

            fetch('/Admin/UnbanUser', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': getToken()
                },
                body: `id=${userId}`
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    showToast('✅ ' + data.message, 'success');
                    setTimeout(() => location.reload(), 800);
                } else {
                    showToast(data.message || '操作失败', 'error');
                }
            })
            .catch(() => showToast('操作失败，请重试', 'error'));
        }

        // ============================================================
        // 4. 删除用户
        // ============================================================
        function deleteUser(userId) {
            const reason = prompt('删除原因：', '违反网站规定');
            if (reason === null) return;

            if (!confirm(`确认删除该用户吗？此操作不可恢复！`)) return;

            fetch('/Admin/DeleteUser', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': getToken()
                },
                body: `id=${userId}&reason=${encodeURIComponent(reason)}&note=`
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    showToast('🗑️ ' + data.message, 'success');
                    setTimeout(() => location.reload(), 800);
                } else {
                    showToast(data.message || '操作失败', 'error');
                }
            })
            .catch(() => showToast('操作失败，请重试', 'error'));
        }

        // ============================================================
        // 5. 筛选功能
        // ============================================================
        function applyFilters() {
            const status = document.getElementById('filterStatus').value;
            const search = document.getElementById('searchInput').value.toLowerCase();

            const rows = document.querySelectorAll('.user-row');
            let count = 0;

            rows.forEach(row => {
                let show = true;
                const rowStatus = row.dataset.status;
                const rowSearch = row.dataset.search?.toLowerCase() || '';

                if (status !== 'all' && rowStatus !== status) show = false;
                if (search && !rowSearch.includes(search)) show = false;

                row.style.display = show ? '' : 'none';
                if (show) count++;
            });

            showToast(`显示 ${count} 个用户`, 'info');
        }

        function resetFilters() {
            document.getElementById('filterStatus').value = 'all';
            document.getElementById('searchInput').value = '';
            document.querySelectorAll('.user-row').forEach(row => {
                row.style.display = '';
            });
            showToast('已重置筛选', 'info');
        }

        document.getElementById('searchInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') applyFilters();
        });
    </script>
}
