@model MyPersonalWebsite.Models.Blog

@{
    ViewData["Title"] = "发布新文章";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-pencil-square"></i> 发布新文章</h2>
        <a href="/Admin/Blogs" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> 返回
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="CreateBlog" method="post">
                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-semibold">标题</label>
                    <input asp-for="Title" class="form-control form-control-lg" placeholder="输入文章标题" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Summary" class="form-label fw-semibold">摘要</label>
                    <input asp-for="Summary" class="form-control" placeholder="简短描述文章内容" />
                    <span asp-validation-for="Summary" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Content" class="form-label fw-semibold">内容（支持 HTML）</label>
                    <textarea asp-for="Content" class="form-control" rows="12" 
                              placeholder="输入文章内容，支持 HTML 标签"></textarea>
                    <span asp-validation-for="Content" class="text-danger"></span>
                    <small class="text-muted">支持 HTML 标签，如 &lt;p&gt;、&lt;strong&gt;、&lt;ul&gt; 等</small>
                </div>

                <div class="mb-3">
                    <label asp-for="CoverImageUrl" class="form-label fw-semibold">封面图链接</label>
                    <input asp-for="CoverImageUrl" class="form-control" placeholder="/images/cover.jpg" />
                    <span asp-validation-for="CoverImageUrl" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save"></i> 发布文章
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}