@model List<MyPersonalWebsite.Models.Notification>

@{
    ViewData["Title"] = "通知管理";
    var isAdmin = Context.Session.GetInt32("IsAdmin") ?? 0;
    if (isAdmin != 1)
    {
        Context.Response.Redirect("/Auth/Login");
        return;
    }

    var total = Model.Count;
    var readCount = Model.Count(n => n.IsRead);
    var unreadCount = total - readCount;

    // 按通知类型统计
    var infoCount = Model.Count(n => n.Type == "info");
    var successCount = Model.Count(n => n.Type == "success");
    var warningCount = Model.Count(n => n.Type == "warning");
    var dangerCount = Model.Count(n => n.Type == "danger");
}

<style>
    .admin-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
    }

    .admin-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid rgba(255,255,255,0.04);
    }

    .admin-header h1 {
        font-size: 1.8rem;
        font-weight: 700;
        background: linear-gradient(135deg, #8B5CF6 0%, #EC4899 50%, #F59E0B 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin: 0;
    }

    .btn-glass {
        padding: 0.5rem 1.5rem;
        border-radius: 40px;
        border: 1px solid rgba(255,255,255,0.06);
        background: rgba(255,255,255,0.04);
        color: rgba(255,255,255,0.7);
        text-decoration: none;
        transition: all 0.3s ease;
        font-size: 0.9rem;
        cursor: pointer;
        display: inline-block;
    }

    .btn-glass:hover {
        background: rgba(255,255,255,0.08);
        color: #fff;
    }

    .btn-glass.primary {
        background: linear-gradient(135deg, #8B5CF6, #EC4899);
        border: none;
        color: #fff;
    }

    .btn-glass.primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 32px rgba(108,60,225,0.2);
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .stat-card {
        background: rgba(255,255,255,0.03);
        border-radius: 16px;
        padding: 1rem 1.2rem;
        border: 1px solid rgba(255,255,255,0.04);
        text-align: center;
    }

    .stat-card .number {
        font-size: 1.8rem;
        font-weight: 700;
        color: #fff;
    }

    .stat-card .label {
        font-size: 0.75rem;
        color: rgba(255,255,255,0.4);
        margin-top: 0.2rem;
    }

    .stat-card.total .number { color: #4facfe; }
    .stat-card.read .number { color: #28a745; }
    .stat-card.unread .number { color: #ffc107; }
    .stat-card.info .number { color: #4facfe; }
    .stat-card.success .number { color: #28a745; }
    .stat-card.warning .number { color: #ffc107; }
    .stat-card.danger .number { color: #dc3545; }

    .table-wrapper {
        background: rgba(255,255,255,0.02);
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.04);
        overflow-x: auto;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.85rem;
        min-width: 800px;
    }

    th {
        text-align: left;
        padding: 0.8rem 1rem;
        background: rgba(255,255,255,0.03);
        color: rgba(255,255,255,0.4);
        font-weight: 500;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        border-bottom: 1px solid rgba(255,255,255,0.04);
        white-space: nowrap;
    }

    td {
        padding: 0.7rem 1rem;
        border-bottom: 1px solid rgba(255,255,255,0.03);
        color: rgba(255,255,255,0.8);
        vertical-align: middle;
    }

    tr:hover td {
        background: rgba(255,255,255,0.02);
    }

    .badge {
        font-size: 0.65rem;
        padding: 0.15rem 0.7rem;
        border-radius: 20px;
        font-weight: 500;
        display: inline-block;
    }

    .badge-info {
        background: rgba(79,172,254,0.12);
        color: #4facfe;
        border: 1px solid rgba(79,172,254,0.06);
    }

    .badge-success {
        background: rgba(40,167,69,0.12);
        color: #28a745;
        border: 1px solid rgba(40,167,69,0.06);
    }

    .badge-warning {
        background: rgba(255,193,7,0.12);
        color: #ffc107;
        border: 1px solid rgba(255,193,7,0.06);
    }

    .badge-danger {
        background: rgba(220,53,69,0.12);
        color: #dc3545;
        border: 1px solid rgba(220,53,69,0.06);
    }

    .badge-read {
        background: rgba(40,167,69,0.08);
        color: #28a745;
        border: 1px solid rgba(40,167,69,0.04);
    }

    .badge-unread {
        background: rgba(255,193,7,0.08);
        color: #ffc107;
        border: 1px solid rgba(255,193,7,0.04);
    }

    .filter-bar {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: 1.5rem;
        padding: 1rem 1.5rem;
        background: rgba(255,255,255,0.02);
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.04);
        align-items: center;
    }

    .filter-bar select,
    .filter-bar input {
        padding: 0.4rem 1rem;
        border-radius: 30px;
        border: 1px solid rgba(255,255,255,0.06);
        background: rgba(255,255,255,0.04);
        color: #e0e0e0;
        font-size: 0.85rem;
        outline: none;
    }

    .filter-bar select:focus,
    .filter-bar input:focus {
        border-color: rgba(79,172,254,0.3);
    }

    .filter-bar select option {
        background: #1a1a2e;
        color: #e0e0e0;
    }

    .empty-state {
        text-align: center;
        padding: 3rem 2rem;
        color: rgba(255,255,255,0.15);
    }

    .toast-container {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        z-index: 2000;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        align-items: flex-end;
    }

    .toast-msg {
        padding: 0.8rem 1.8rem;
        border-radius: 40px;
        color: #fff;
        font-weight: 500;
        animation: slideUp 0.4s ease;
        font-size: 0.9rem;
        backdrop-filter: blur(10px);
        background: rgba(0,0,0,0.6);
        border: 1px solid rgba(255,255,255,0.04);
    }

    .toast-msg.success { background: rgba(40,167,69,0.8); }
    .toast-msg.error { background: rgba(220,53,69,0.8); }
    .toast-msg.info { background: rgba(79,172,254,0.8); }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(20px) scale(0.95); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }

    .btn-sm {
        padding: 0.2rem 0.7rem;
        border: none;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .btn-sm.danger {
        background: rgba(220,53,69,0.08);
        color: #dc3545;
    }

    .btn-sm.danger:hover {
        background: rgba(220,53,69,0.15);
    }

    .btn-sm.primary {
        background: rgba(79,172,254,0.12);
        color: #4facfe;
    }

    .btn-sm.primary:hover {
        background: rgba(79,172,254,0.2);
    }

    @@media (max-width: 768px) {
        .admin-header h1 { font-size: 1.3rem; }
        .filter-bar { flex-direction: column; align-items: stretch; }
        .stats-grid { grid-template-columns: repeat(2, 1fr); }
    }
</style>

<div class="admin-container">

    <div class="admin-header">
        <h1>📬 通知管理</h1>
        <div>
            <a href="/Admin/Dashboard" class="btn-glass">← 返回后台</a>
            <a href="/Admin/SendNotification" class="btn-glass primary" style="margin-left:0.5rem;">
                ✍️ 发布通知
            </a>
        </div>
    </div>

    <!-- 统计 -->
    <div class="stats-grid">
        <div class="stat-card total">
            <div class="number">@total</div>
            <div class="label">📬 总通知</div>
        </div>
        <div class="stat-card read">
            <div class="number">@readCount</div>
            <div class="label">✅ 已阅读</div>
        </div>
        <div class="stat-card unread">
            <div class="number">@unreadCount</div>
            <div class="label">⏳ 未阅读</div>
        </div>
        <div class="stat-card info">
            <div class="number">@infoCount</div>
            <div class="label">ℹ️ 信息</div>
        </div>
        <div class="stat-card success">
            <div class="number">@successCount</div>
            <div class="label">✅ 成功</div>
        </div>
        <div class="stat-card warning">
            <div class="number">@warningCount</div>
            <div class="label">⚠️ 警告</div>
        </div>
        <div class="stat-card danger">
            <div class="number">@dangerCount</div>
            <div class="label">🔥 重要</div>
        </div>
    </div>

    <!-- 筛选 -->
    <div class="filter-bar">
        <span style="color:rgba(255,255,255,0.3);font-size:0.8rem;">🔍 筛选：</span>
        <select id="filterType">
            <option value="all">全部类型</option>
            <option value="info">ℹ️ 信息</option>
            <option value="success">✅ 成功</option>
            <option value="warning">⚠️ 警告</option>
            <option value="danger">🔥 重要</option>
        </select>
        <select id="filterStatus">
            <option value="all">全部状态</option>
            <option value="read">✅ 已读</option>
            <option value="unread">⏳ 未读</option>
        </select>
        <input type="text" id="searchInput" placeholder="搜索标题或内容..." style="flex:1;min-width:160px;" />
        <button class="btn-glass" onclick="applyFilters()" style="padding:0.3rem 1.2rem;">应用</button>
        <button class="btn-glass" onclick="resetFilters()" style="padding:0.3rem 1.2rem;background:rgba(255,255,255,0.04);color:rgba(255,255,255,0.4);">重置</button>
    </div>

    <!-- 表格 -->
    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>标题</th>
                    <th>内容</th>
                    <th>类型</th>
                    <th>状态</th>
                    <th>接收人</th>
                    <th>发送时间</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    foreach (var n in Model.OrderByDescending(n => n.CreatedAt))
                    {
                        var typeClass = n.Type switch
                        {
                            "success" => "badge-success",
                            "warning" => "badge-warning",
                            "danger" => "badge-danger",
                            _ => "badge-info"
                        };
                        var statusClass = n.IsRead ? "badge-read" : "badge-unread";
                        var statusText = n.IsRead ? "✅ 已读" : "⏳ 未读";

                        <tr class="notif-row"
                            data-type="@n.Type"
                            data-status="@(n.IsRead ? "read" : "unread")"
                            data-search="@(n.Title + " " + n.Message)">
                            <td style="color:rgba(255,255,255,0.3);font-size:0.8rem;">#@n.Id</td>
                            <td><strong style="color:#fff;">@n.Title</strong></td>
                            <td style="color:rgba(255,255,255,0.5);font-size:0.85rem;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@n.Message</td>
                            <td><span class="badge @typeClass">@(n.Type switch { "success" => "✅ 成功", "warning" => "⚠️ 警告", "danger" => "🔥 重要", _ => "ℹ️ 信息" })</span></td>
                            <td><span class="badge @statusClass">@statusText</span></td>
                            <td style="color:rgba(255,255,255,0.4);font-size:0.8rem;">
                                @{
                                    var user = ViewBag.Users as List<MyPersonalWebsite.Models.User>;
                                    var targetUser = user?.FirstOrDefault(u => u.Id == n.UserId);
                                    @(targetUser?.Username ?? "已删除用户")
                                }
                            </td>
                            <td style="font-size:0.75rem;color:rgba(255,255,255,0.25);">@n.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                <button class="btn-sm primary" onclick="viewNotification(@n.Id)">👁️ 详情</button>
                                <button class="btn-sm danger" onclick="deleteNotification(@n.Id)">🗑️</button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8">
                            <div class="empty-state">📭 暂无通知记录</div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>

<!-- Toast -->
<div class="toast-container" id="toastContainer"></div>

@section Scripts {
    <script>
        function getToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        }

        function showToast(message, type = 'info') {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast-msg ${type}`;
            toast.textContent = message;
            container.appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(20px)';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        function viewNotification(id) {
            // 查看通知详情（可以弹窗显示完整内容）
            const row = document.querySelector(`.notif-row td:first-child`)?.['parentElement'];
            if (row) {
                const title = row.querySelector('td:nth-child(2)')?.textContent || '';
                const content = row.querySelector('td:nth-child(3)')?.textContent || '';
                alert(`📬 通知详情\n\n标题：${title}\n内容：${content}`);
            }
        }

        function deleteNotification(id) {
            if (!confirm('确定删除这条通知吗？')) return;
            const token = getToken();
            fetch('/Admin/DeleteNotification', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: `id=${id}`
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    showToast('✅ 删除成功', 'success');
                    setTimeout(() => location.reload(), 800);
                } else {
                    showToast(data.message || '删除失败', 'error');
                }
            })
            .catch(() => showToast('操作失败，请重试', 'error'));
        }

        function applyFilters() {
            const type = document.getElementById('filterType').value;
            const status = document.getElementById('filterStatus').value;
            const search = document.getElementById('searchInput').value.toLowerCase();
            const rows = document.querySelectorAll('.notif-row');
            let count = 0;

            rows.forEach(row => {
                let show = true;
                const rowType = row.dataset.type;
                const rowStatus = row.dataset.status;
                const rowSearch = row.dataset.search?.toLowerCase() || '';

                if (type !== 'all' && rowType !== type) show = false;
                if (status !== 'all' && rowStatus !== status) show = false;
                if (search && !rowSearch.includes(search)) show = false;

                row.style.display = show ? '' : 'none';
                if (show) count++;
            });

            showToast(`显示 ${count} 条通知`, 'info');
        }

        function resetFilters() {
            document.getElementById('filterType').value = 'all';
            document.getElementById('filterStatus').value = 'all';
            document.getElementById('searchInput').value = '';
            document.querySelectorAll('.notif-row').forEach(row => {
                row.style.display = '';
            });
            showToast('已重置筛选', 'info');
        }

        document.getElementById('searchInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') applyFilters();
        });
    </script>
}
