@model List<MyPersonalWebsite.Models.AboutMe>

@{
    ViewData["Title"] = "编辑关于我";
    var isAdmin = Context.Session.GetInt32("IsAdmin") ?? 0;
    if (isAdmin != 1)
    {
        Context.Response.Redirect("/Auth/Login");
        return;
    }
}

<style>
    .admin-container { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .admin-header { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; margin-bottom: 2rem; border-bottom: 1px solid rgba(255,255,255,0.04); padding-bottom: 1.5rem; }
    .admin-header h1 { font-size: 1.8rem; font-weight: 700; background: linear-gradient(135deg,#8B5CF6,#EC4899,#F59E0B); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin: 0; }

    .edit-card { background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.04); border-radius: 20px; padding: 1.8rem 2rem; margin-bottom: 1.5rem; transition: all 0.3s ease; }
    .edit-card:hover { border-color: rgba(255,255,255,0.06); }
    .edit-card .card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; }
    .edit-card .card-header h3 { color: #fff; font-weight: 600; font-size: 1.1rem; margin: 0; }
    .edit-card .card-header .badge { font-size: 0.65rem; padding: 0.15rem 0.6rem; border-radius: 20px; background: rgba(139,92,246,0.12); color: #8B5CF6; border: 1px solid rgba(139,92,246,0.06); }

    .edit-card textarea { width: 100%; padding: 0.8rem 1rem; border-radius: 12px; border: 1px solid rgba(255,255,255,0.04); background: rgba(255,255,255,0.02); color: #e0e0e0; font-size: 0.9rem; transition: all 0.3s ease; outline: none; resize: vertical; min-height: 100px; font-family: inherit; }
    .edit-card textarea:focus { border-color: rgba(108,60,225,0.15); background: rgba(255,255,255,0.04); box-shadow: 0 0 0 4px rgba(108,60,225,0.04); }

    .edit-card input { width: 100%; padding: 0.7rem 1rem; border-radius: 12px; border: 1px solid rgba(255,255,255,0.04); background: rgba(255,255,255,0.02); color: #e0e0e0; font-size: 0.9rem; transition: all 0.3s ease; outline: none; }
    .edit-card input:focus { border-color: rgba(108,60,225,0.15); background: rgba(255,255,255,0.04); box-shadow: 0 0 0 4px rgba(108,60,225,0.04); }
    .edit-card input::placeholder { color: rgba(255,255,255,0.08); }

    .btn-save { padding: 0.5rem 1.5rem; border: none; border-radius: 40px; background: linear-gradient(135deg, #8B5CF6, #EC4899); color: #fff; font-weight: 500; font-size: 0.85rem; cursor: pointer; transition: all 0.3s ease; }
    .btn-save:hover { transform: scale(1.02); box-shadow: 0 4px 20px rgba(108,60,225,0.2); }

    .btn-glass { padding: 0.5rem 1.5rem; border-radius: 40px; border: 1px solid rgba(255,255,255,0.04); background: rgba(255,255,255,0.02); color: rgba(255,255,255,0.4); text-decoration: none; font-size: 0.85rem; transition: all 0.3s ease; }
    .btn-glass:hover { background: rgba(255,255,255,0.04); color: #fff; }

    .toast-container { position: fixed; bottom: 2rem; right: 2rem; z-index: 2000; display: flex; flex-direction: column; gap: 0.5rem; align-items: flex-end; }
    .toast-msg { padding: 0.8rem 1.8rem; border-radius: 40px; color: #fff; font-weight: 500; animation: slideUp 0.4s ease; font-size: 0.9rem; backdrop-filter: blur(10px); background: rgba(0,0,0,0.6); border: 1px solid rgba(255,255,255,0.04); }
    .toast-msg.success { background: rgba(40,167,69,0.8); }
    .toast-msg.error { background: rgba(220,53,69,0.8); }
    .toast-msg.info { background: rgba(79,172,254,0.8); }
    @@keyframes slideUp { from { opacity: 0; transform: translateY(20px) scale(0.95); } to { opacity: 1; transform: translateY(0) scale(1); } }

    .social-input-group { display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center; }
    .social-input-group input { flex: 1; min-width: 150px; }
    .social-input-group .platform-label { color: rgba(255,255,255,0.2); font-size: 0.8rem; min-width: 60px; }
</style>

<div class="admin-container">

    <div class="admin-header">
        <h1>📝 编辑关于我</h1>
        <div>
            <a href="/Admin/Dashboard" class="btn-glass">← 返回后台</a>
            <a href="/Home/About" class="btn-glass" target="_blank">👁️ 预览</a>
        </div>
    </div>

    <form id="aboutForm">
        @foreach (var section in Model)
        {
            <div class="edit-card">
                <div class="card-header">
                    <h3>@section.Title</h3>
                    <span class="badge">@section.SectionKey</span>
                </div>

                @if (section.SectionKey == "social")
                {
                    // 解析社交链接
                    var links = section.Content?.Split('|') ?? new string[0];
                    var github = links.FirstOrDefault(l => l.StartsWith("github:"))?.Replace("github:", "") ?? "";
                    var twitter = links.FirstOrDefault(l => l.StartsWith("twitter:"))?.Replace("twitter:", "") ?? "";
                    var linkedin = links.FirstOrDefault(l => l.StartsWith("linkedin:"))?.Replace("linkedin:", "") ?? "";
                    var discord = links.FirstOrDefault(l => l.StartsWith("discord:"))?.Replace("discord:", "") ?? "";

                    <div class="social-input-group">
                        <span class="platform-label">GitHub</span>
                        <input type="text" id="social_github" value="@github" placeholder="https://github.com/..." />
                    </div>
                    <div class="social-input-group" style="margin-top:0.5rem;">
                        <span class="platform-label">Twitter</span>
                        <input type="text" id="social_twitter" value="@twitter" placeholder="https://twitter.com/..." />
                    </div>
                    <div class="social-input-group" style="margin-top:0.5rem;">
                        <span class="platform-label">LinkedIn</span>
                        <input type="text" id="social_linkedin" value="@linkedin" placeholder="https://linkedin.com/in/..." />
                    </div>
                    <div class="social-input-group" style="margin-top:0.5rem;">
                        <span class="platform-label">Discord</span>
                        <input type="text" id="social_discord" value="@discord" placeholder="https://discord.gg/..." />
                    </div>
                }
                else
                {
                    <textarea id="content_@section.Id" data-key="@section.SectionKey" rows="5">@section.Content</textarea>
                }
            </div>
        }
    </form>

    <button class="btn-save" onclick="saveAll()" style="padding:0.8rem 3rem;font-size:1rem;width:100%;">💾 保存所有修改</button>

</div>

<div class="toast-container" id="toastContainer"></div>

@section Scripts {
    <script>
        function showToast(message, type = 'info') {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast-msg ${type}`;
            toast.textContent = message;
            container.appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(20px)';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        function saveAll() {
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

            const data = {};
            document.querySelectorAll('textarea[data-key]').forEach(el => {
                data[el.dataset.key] = el.value;
            });

            data['social_github'] = document.getElementById('social_github')?.value || '';
            data['social_twitter'] = document.getElementById('social_twitter')?.value || '';
            data['social_linkedin'] = document.getElementById('social_linkedin')?.value || '';
            data['social_discord'] = document.getElementById('social_discord')?.value || '';

            fetch('/Admin/UpdateAboutMe', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify(data)
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    showToast('✅ 保存成功！', 'success');
                } else {
                    showToast(data.message || '保存失败', 'error');
                }
            })
            .catch(() => showToast('保存失败，请重试', 'error'));
        }
    </script>
}
