@model MyPersonalWebsite.Models.AuditResultViewModel

@{
    ViewData["Title"] = Model.Title;
}

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background: #0a0a0f;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .audit-container {
        max-width: 520px;
        width: 100%;
        margin: 2rem;
        padding: 3rem 2.5rem;
        text-align: center;
        background: rgba(255, 255, 255, 0.02);
        backdrop-filter: blur(40px);
        border: 1px solid rgba(255, 255, 255, 0.04);
        border-radius: 32px;
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.3);
        animation: fadeIn 0.5s ease;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(30px) scale(0.96);
        }
        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .audit-container .icon-wrap {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.2rem;
        font-size: 2.8rem;
    }

    .audit-container .icon-wrap.success {
        background: rgba(40, 167, 69, 0.12);
        border: 1px solid rgba(40, 167, 69, 0.15);
    }

    .audit-container .icon-wrap.fail {
        background: rgba(220, 53, 69, 0.12);
        border: 1px solid rgba(220, 53, 69, 0.15);
    }

    .audit-container .icon-wrap.info {
        background: rgba(255, 193, 7, 0.12);
        border: 1px solid rgba(255, 193, 7, 0.15);
    }

    .audit-container h1 {
        color: #fff;
        font-weight: 700;
        font-size: 1.6rem;
        margin-bottom: 0.4rem;
    }

    .audit-container .subtitle {
        color: rgba(255, 255, 255, 0.3);
        font-size: 0.9rem;
    }

    .audit-container .divider {
        width: 60px;
        height: 2px;
        background: rgba(255, 255, 255, 0.04);
        margin: 1.2rem auto;
        border-radius: 4px;
    }

    .audit-container .message-box {
        background: rgba(255, 255, 255, 0.03);
        border-radius: 16px;
        padding: 1.2rem 1.5rem;
        margin: 1rem 0;
        border: 1px solid rgba(255, 255, 255, 0.04);
    }

    .audit-container .message-box .msg {
        color: rgba(255, 255, 255, 0.8);
        font-size: 1rem;
        line-height: 1.6;
    }

    .audit-container .message-box .msg strong {
        color: #fff;
    }

    .audit-container .detail {
        color: rgba(255, 255, 255, 0.25);
        font-size: 0.85rem;
        margin-top: 0.5rem;
    }

    .audit-container .user-info {
        display: flex;
        justify-content: center;
        gap: 1.5rem;
        flex-wrap: wrap;
        margin: 1rem 0;
        padding: 0.8rem;
        background: rgba(255, 255, 255, 0.02);
        border-radius: 12px;
    }

    .audit-container .user-info .item {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        color: rgba(255, 255, 255, 0.3);
        font-size: 0.85rem;
    }

    .audit-container .user-info .item .value {
        color: rgba(255, 255, 255, 0.7);
    }

    .audit-container .btn-group {
        display: flex;
        gap: 0.8rem;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 1.5rem;
    }

    .audit-container .btn {
        display: inline-block;
        padding: 0.7rem 2rem;
        border-radius: 40px;
        border: 1px solid rgba(255, 255, 255, 0.06);
        background: rgba(255, 255, 255, 0.03);
        color: rgba(255, 255, 255, 0.6);
        text-decoration: none;
        font-weight: 500;
        font-size: 0.9rem;
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .audit-container .btn:hover {
        background: rgba(255, 255, 255, 0.06);
        color: #fff;
        transform: translateY(-2px);
    }

    .audit-container .btn.primary {
        background: linear-gradient(135deg, #8B5CF6, #EC4899);
        border: none;
        color: #fff;
    }

    .audit-container .btn.primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 32px rgba(108, 60, 225, 0.2);
    }

    @@media (max-width: 480px) {
        .audit-container {
            padding: 2rem 1.2rem;
            margin: 1rem;
        }
        .audit-container .icon-wrap {
            width: 60px;
            height: 60px;
            font-size: 2rem;
        }
        .audit-container h1 {
            font-size: 1.3rem;
        }
        .audit-container .user-info {
            flex-direction: column;
            align-items: center;
            gap: 0.4rem;
        }
    }
</style>

<div class="audit-container">
    <!-- 图标 -->
    <div class="icon-wrap @Model.IconType">
        @if (Model.IconType == "success")
        {
            <span>✅</span>
        }
        else if (Model.IconType == "fail")
        {
            <span>❌</span>
        }
        else
        {
            <span>ℹ️</span>
        }
    </div>

    <!-- 标题 -->
    <h1>@Html.Raw(Model.Title)</h1>
    <p class="subtitle">审核结果</p>

    <div class="divider"></div>

    <!-- 消息 -->
    <div class="message-box">
        <div class="msg">@Html.Raw(Model.Message)</div>
        @if (!string.IsNullOrEmpty(Model.Detail))
        {
            <div class="detail">@Model.Detail</div>
        }
    </div>

    <!-- 用户信息 -->
    @if (!string.IsNullOrEmpty(Model.Username) || !string.IsNullOrEmpty(Model.Email))
    {
        <div class="user-info">
            @if (!string.IsNullOrEmpty(Model.Username))
            {
                <div class="item">
                    👤 <span class="value">@Model.Username</span>
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.Email))
            {
                <div class="item">
                    📧 <span class="value">@Model.Email</span>
                </div>
            }
        </div>
    }

    <!-- 按钮 -->
    <div class="btn-group">
        <a href="/" class="btn">🏠 返回首页</a>
        <a href="/Admin/Dashboard" class="btn primary">📊 进入后台</a>
    </div>
</div>
