@model MyPersonalWebsite.Models.Blog

@{
    ViewData["Title"] = Model.Title;
    var isLiked = ViewBag.IsLiked as bool? ?? false;
    var currentUserId = ViewBag.CurrentUserId as int?;
}

<style>
    .blog-detail-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 1rem 0;
    }

    .blog-detail-card {
        background: rgba(255,255,255,0.02);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.04);
        border-radius: 24px;
        padding: 2.5rem 3rem;
        position: relative;
        overflow: hidden;
    }

    .blog-detail-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(135deg, #8B5CF6, #EC4899, #F59E0B);
        opacity: 0.3;
    }

    .blog-detail-card .cover-image {
        width: 100%;
        max-height: 350px;
        border-radius: 16px;
        object-fit: cover;
        margin-bottom: 1.5rem;
        background: rgba(255,255,255,0.02);
        border: 1px solid rgba(255,255,255,0.04);
    }

    .blog-detail-card .title {
        font-size: 2.2rem;
        font-weight: 800;
        color: #fff;
        margin-bottom: 0.5rem;
        line-height: 1.2;
    }

    .blog-detail-card .meta {
        color: rgba(255,255,255,0.25);
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid rgba(255,255,255,0.04);
        margin-bottom: 1.5rem;
    }

    .blog-detail-card .content {
        color: rgba(255,255,255,0.75);
        line-height: 1.9;
        font-size: 1.05rem;
    }

    .blog-detail-card .content p {
        margin-bottom: 1rem;
    }

    .blog-detail-card .content img {
        max-width: 100%;
        border-radius: 12px;
        margin: 1rem 0;
        border: 1px solid rgba(255,255,255,0.04);
    }

    .blog-detail-card .content h2,
    .blog-detail-card .content h3,
    .blog-detail-card .content h4 {
        color: #fff;
        margin-top: 1.5rem;
        margin-bottom: 0.8rem;
    }

    .blog-detail-card .content ul,
    .blog-detail-card .content ol {
        padding-left: 1.5rem;
        margin-bottom: 1rem;
    }

    .blog-detail-card .content blockquote {
        border-left: 3px solid #8B5CF6;
        padding-left: 1.2rem;
        margin: 1rem 0;
        color: rgba(255,255,255,0.4);
        font-style: italic;
    }

    .blog-detail-card .content code {
        background: rgba(255,255,255,0.04);
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
        font-size: 0.9rem;
        color: #8B5CF6;
    }

    .blog-detail-card .content pre {
        background: rgba(0,0,0,0.3);
        padding: 1rem;
        border-radius: 12px;
        overflow-x: auto;
        font-size: 0.9rem;
        color: rgba(255,255,255,0.8);
        border: 1px solid rgba(255,255,255,0.04);
        margin: 1rem 0;
    }

    .blog-detail-card .content table {
        width: 100%;
        border-collapse: collapse;
        margin: 1rem 0;
        font-size: 0.9rem;
    }

    .blog-detail-card .content table th,
    .blog-detail-card .content table td {
        padding: 0.5rem 1rem;
        border: 1px solid rgba(255,255,255,0.04);
    }

    .blog-detail-card .content table th {
        background: rgba(255,255,255,0.04);
        color: #fff;
        font-weight: 600;
    }

    .blog-detail-card .actions-bar {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(255,255,255,0.04);
        margin-top: 1.5rem;
    }

    .blog-detail-card .actions-bar .btn-like {
        padding: 0.5rem 1.5rem;
        border: none;
        border-radius: 40px;
        background: rgba(236,72,153,0.08);
        color: rgba(255,255,255,0.6);
        cursor: pointer;
        transition: all 0.3s ease;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .blog-detail-card .actions-bar .btn-like:hover {
        background: rgba(236,72,153,0.12);
    }

    .blog-detail-card .actions-bar .btn-like.liked {
        background: rgba(236,72,153,0.15);
        color: #EC4899;
    }

    .blog-detail-card .actions-bar .btn-back {
        padding: 0.5rem 1.5rem;
        border: 1px solid rgba(255,255,255,0.04);
        border-radius: 40px;
        background: rgba(255,255,255,0.02);
        color: rgba(255,255,255,0.3);
        text-decoration: none;
        font-size: 0.85rem;
        transition: all 0.3s ease;
    }

    .blog-detail-card .actions-bar .btn-back:hover {
        background: rgba(255,255,255,0.04);
        color: rgba(255,255,255,0.6);
    }

    /* 响应式 */
    @@media (max-width: 640px) {
        .blog-detail-card {
            padding: 1.5rem 1.2rem;
        }
        .blog-detail-card .title {
            font-size: 1.6rem;
        }
        .blog-detail-card .meta {
            font-size: 0.75rem;
        }
    }
</style>

<div class="blog-detail-container">
    <div class="blog-detail-card">

        @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
        {
            <img class="cover-image" src="@Model.CoverImageUrl" alt="@Model.Title" />
        }

        <h1 class="title">@Model.Title</h1>

        <div class="meta">
            <span><i class="bi bi-calendar3"></i> @Model.PublishDate.ToString("yyyy年MM月dd日")</span>
            <span><i class="bi bi-heart"></i> @Model.LikeCount 赞</span>
        </div>

        <div class="content">
            @Html.Raw(Model.Content)
        </div>

        <div class="actions-bar">
            @if (currentUserId.HasValue)
            {
                <button class="btn-like @(isLiked ? "liked" : "")" onclick="toggleLike(@Model.Id, this)">
                    <i class="bi @(isLiked ? "bi-heart-fill" : "bi-heart")"></i>
                    <span id="likeCount-@Model.Id">@Model.LikeCount</span>
                </button>
            }
            else
            {
                <span class="btn-like" style="cursor:default;opacity:0.4;">
                    <i class="bi bi-heart"></i> @Model.LikeCount
                </span>
            }

            <a href="/Blog" class="btn-back"><i class="bi bi-arrow-left"></i> 返回列表</a>
        </div>

    </div>
</div>

<script>
    function toggleLike(blogId, btn) {
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        fetch('/Blog/ToggleLike', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': token },
            body: `blogId=${blogId}`
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                const countEl = document.getElementById(`likeCount-${blogId}`);
                if (countEl) countEl.textContent = data.likeCount;
                if (data.isLiked) {
                    btn.classList.add('liked');
                    btn.querySelector('i').className = 'bi bi-heart-fill';
                } else {
                    btn.classList.remove('liked');
                    btn.querySelector('i').className = 'bi bi-heart';
                }
            }
        });
    }
</script>
