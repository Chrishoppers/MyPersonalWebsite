@model List<MyPersonalWebsite.Models.Blog>

@{
    ViewData["Title"] = "博客列表";
}

<h2><i class="bi bi-journal"></i> 所有文章</h2>
<hr>

<div class="row">
    @if (Model != null && Model.Any())
    {
        foreach (var blog in Model)
        {
            var isLiked = ViewBag.LikedIds != null && ((HashSet<int>)ViewBag.LikedIds).Contains(blog.Id);
            var currentUserId = ViewBag.CurrentUserId as int?;

            <div class="col-md-6 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h4 class="card-title">@blog.Title</h4>
                        <p class="text-muted small">
                            <i class="bi bi-calendar3"></i> @blog.PublishDate.ToString("yyyy年MM月dd日")
                        </p>
                        <p class="card-text">@blog.Summary</p>

                        <!-- ⭐ 点赞按钮 -->
                        <div class="d-flex align-items-center gap-3 mt-2">
                            @if (currentUserId.HasValue)
                            {
                                <button class="btn btn-outline-primary btn-sm like-btn @(isLiked ? "liked" : "")" 
                                        onclick="toggleLike(@blog.Id, this)">
                                    <i class="bi @(isLiked ? "bi-heart-fill" : "bi-heart")"></i>
                                    <span class="like-count" id="likeCount-@blog.Id">@blog.LikeCount</span>
                                </button>
                            }
                            else
                            {
                                <span class="btn btn-outline-secondary btn-sm" style="cursor:default;">
                                    <i class="bi bi-heart"></i> <span class="like-count">@blog.LikeCount</span>
                                </span>
                            }
                            <a href="/Blog/Details/@blog.Id" class="btn btn-primary btn-sm">
                                阅读全文 <i class="bi bi-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col">
            <div class="alert alert-info">还没有博客，敬请期待！</div>
        </div>
    }
</div>

<style>
    .like-btn {
        transition: all 0.2s ease;
    }
    .like-btn.liked {
        background: #dc3545;
        border-color: #dc3545;
        color: #fff;
    }
    .like-btn.liked:hover {
        background: #c82333;
        border-color: #bd2130;
        color: #fff;
    }
    .like-btn .bi-heart-fill {
        color: #fff;
    }
</style>

@section Scripts {
    <script>
        function toggleLike(blogId, btn) {
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

            fetch('/Blog/ToggleLike', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: `blogId=${blogId}`
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    // 更新点赞数
                    const countEl = document.getElementById(`likeCount-${blogId}`);
                    if (countEl) {
                        countEl.textContent = data.likeCount;
                    }

                    // 更新按钮样式
                    if (data.isLiked) {
                        btn.classList.add('liked');
                        btn.querySelector('i').className = 'bi bi-heart-fill';
                    } else {
                        btn.classList.remove('liked');
                        btn.querySelector('i').className = 'bi bi-heart';
                    }

                    // 显示提示
                    showToast(data.message, 'success');
                } else {
                    showToast(data.message || '操作失败', 'error');
                }
            })
            .catch(() => showToast('操作失败，请重试', 'error'));
        }

        function showToast(message, type = 'info') {
            const container = document.getElementById('toastContainer') || createToastContainer();
            const toast = document.createElement('div');
            toast.className = `toast-msg ${type}`;
            toast.textContent = message;
            container.appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(20px)';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        function createToastContainer() {
            const container = document.createElement('div');
            container.id = 'toastContainer';
            container.style.cssText = `
                position: fixed;
                bottom: 2rem;
                right: 2rem;
                z-index: 2000;
                display: flex;
                flex-direction: column;
                gap: 0.5rem;
                align-items: flex-end;
            `;
            document.body.appendChild(container);
            // 添加样式
            const style = document.createElement('style');
            style.textContent = `
                .toast-msg {
                    padding: 0.8rem 1.8rem;
                    border-radius: 40px;
                    color: #fff;
                    font-weight: 500;
                    animation: slideUp 0.4s ease;
                    font-size: 0.9rem;
                    backdrop-filter: blur(10px);
                    background: rgba(0, 0, 0, 0.7);
                    border: 1px solid rgba(255, 255, 255, 0.04);
                    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
                }
                .toast-msg.success { background: rgba(40, 167, 69, 0.85); }
                .toast-msg.error { background: rgba(220, 53, 69, 0.85); }
                .toast-msg.info { background: rgba(79, 172, 254, 0.85); }
                @@keyframes slideUp {
                    from { opacity: 0; transform: translateY(20px) scale(0.95); }
                    to { opacity: 1; transform: translateY(0) scale(1); }
                }
            `;
            document.head.appendChild(style);
            return container;
        }
    </script>
}