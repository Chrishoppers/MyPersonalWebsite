<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Chris hopper</title>

    <!-- 字体 -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <!-- 高级样式 -->
    <link rel="stylesheet" href="~/css/site.css" />

    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <style>
        body {
            background: #0A0A0F;
            color: #FFFFFF;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }
        main {
            padding-top: 1.5rem;
            padding-bottom: 3rem;
        }
        .container {
            max-width: 1200px;
        }
        .navbar-nav .nav-link {
            display: flex;
            align-items: center;
            gap: 0.3rem;
        }
        .nav-avatar {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            object-fit: cover;
            border: 1px solid rgba(255,255,255,0.06);
            flex-shrink: 0;
        }
        .nav-avatar-placeholder {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: rgba(255,255,255,0.04);
            color: rgba(255,255,255,0.3);
            font-size: 0.7rem;
            font-weight: 600;
            flex-shrink: 0;
        }
    </style>
</head>
<body>

    <!-- ===== 高级导航栏 ===== -->
    <nav class="navbar navbar-expand-lg nav-advanced">
        <div class="container">
            <a class="navbar-brand nav-brand" href="/">
                <i class="bi bi-command"></i> Chris hopper
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                    style="border:1px solid rgba(255,255,255,0.06);">
                <span class="navbar-toggler-icon" style="filter:invert(1);"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/"><i class="bi bi-house"></i> 首页</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Blog"><i class="bi bi-journal"></i> 博客</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Home/About"><i class="bi bi-person"></i> 关于</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Home/Contact"><i class="bi bi-envelope"></i> 联系</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Message/Index"><i class="bi bi-chat"></i> 留言</a></li>

                    @{
                        var userId = Context.Session.GetInt32("UserId");
                        var isAdmin = Context.Session.GetInt32("IsAdmin") ?? 0;
                        var username = Context.Session.GetString("Username");
                    }

                    @if (userId.HasValue)
                    {
                        // 获取用户头像
                        MyPersonalWebsite.Models.User? user = null;
                        string? avatarUrl = null;
                        bool isAvatarApproved = false;
                        try
                        {
                            var dataSync = Context.RequestServices.GetService<MyPersonalWebsite.Services.DataSyncService>();
                            if (dataSync != null)
                            {
                                user = await dataSync.GetUserByIdAsync(userId.Value);
                                if (user != null)
                                {
                                    avatarUrl = user.AvatarUrl;
                                    isAvatarApproved = user.IsAvatarApproved;
                                }
                            }
                        }
                        catch { }

                        @if (isAdmin == 1)
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/Admin/Dashboard" style="color:#8B5CF6;">
                                    <i class="bi bi-speedometer2"></i> 管理
                                </a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link" href="/Home/Profile">
                                @if (!string.IsNullOrEmpty(avatarUrl) && isAvatarApproved)
                                {
                                    <img src="@avatarUrl" alt="头像" class="nav-avatar" />
                                }
                                else
                                {
                                    <span class="nav-avatar-placeholder">@(username?.FirstOrDefault().ToString().ToUpper() ?? "?")</span>
                                }
                                <span>@username</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Auth/ChangePassword" style="color:rgba(255,255,255,0.4);">
                                <i class="bi bi-key"></i>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Auth/Logout" style="color:#EC4899;">
                                <i class="bi bi-box-arrow-right"></i>
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" href="/Auth/Login"><i class="bi bi-box-arrow-in-right"></i> 登录</a></li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Auth/Register" style="background:linear-gradient(135deg,#8B5CF6,#EC4899);color:#fff;border-radius:50px;padding:0.4rem 1.2rem;">
                                注册
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- ===== 主体 ===== -->
    <main>
        @RenderBody()
    </main>

    <!-- ===== 高级页脚 ===== -->
    <footer style="border-top:1px solid rgba(255,255,255,0.03);padding:2rem 0;margin-top:2rem;">
        <div class="container text-center">
            <p style="color:rgba(255,255,255,0.3);font-size:0.85rem;">
                © 2026 <span style="background:linear-gradient(135deg,#8B5CF6,#EC4899,#F59E0B);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">Chris hopper</span>
                <br>
                <span style="font-size:0.75rem;color:rgba(255,255,255,0.15);">
                    用 <i class="bi bi-heart-fill" style="color:#EC4899;"></i> 和 ASP.NET Core 10.0 构建
                </span>
            </p>
        </div>
    </footer>

    <!-- ===== 脚本 ===== -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <!-- 页面加载动画 -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.card-advanced, .glass').forEach((el, i) => {
                el.style.opacity = '0';
                el.style.transform = 'translateY(30px)';
                setTimeout(() => {
                    el.style.transition = 'all 0.6s cubic-bezier(0.23, 1, 0.32, 1)';
                    el.style.opacity = '1';
                    el.style.transform = 'translateY(0)';
                }, 100 + i * 80);
            });
        });
    </script>
</body>
</html>
