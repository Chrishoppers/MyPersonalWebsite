@model MyPersonalWebsite.Models.Message

@{
    ViewData["Title"] = "发布留言";
    var username = Context.Session.GetString("Username");
    var userEmail = Context.Session.GetString("UserEmail");
}

<div class="container py-5" style="max-width: 640px;">
    <div class="card border-0 shadow-lg" style="border-radius: 24px; overflow: hidden;">
        <div class="card-header border-0 py-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
            <h4 class="mb-0 text-white text-center">
                <i class="bi bi-pencil-square"></i> 写下你的想法
            </h4>
        </div>
        <div class="card-body p-4">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success rounded-pill">@TempData["Success"]</div>
            }

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger rounded-pill">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <p class="mb-0">@error.ErrorMessage</p>
                    }
                </div>
            }

            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label class="form-label fw-semibold"><i class="bi bi-person"></i> 显示名称</label>
                    <input type="text" class="form-control form-control-lg rounded-pill" 
                           value="@username" disabled style="background: #f8f9fa;" />
                    <small class="text-muted">使用你的用户名显示</small>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold"><i class="bi bi-envelope"></i> 邮箱</label>
                    <input type="email" class="form-control form-control-lg rounded-pill" 
                           value="@userEmail" disabled style="background: #f8f9fa;" />
                    <small class="text-muted">管理员回复将通过此邮箱通知您</small>
                </div>

                <div class="mb-4">
                    <label asp-for="Content" class="form-label fw-semibold"><i class="bi bi-chat"></i> 留言内容</label>
                    <textarea asp-for="Content" class="form-control" rows="6" 
                              placeholder="写下你想说的话... 最多100字"
                              style="border-radius: 16px; padding: 1rem; resize: vertical;"
                              maxlength="100"></textarea>
                    <span asp-validation-for="Content" class="text-danger"></span>
                    <div class="text-end text-muted small">
                        <span id="charCount">0</span>/100
                    </div>
                </div>

                <div class="d-flex gap-3">
                    <button type="submit" class="btn btn-primary btn-lg flex-grow-1 rounded-pill" 
                            style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border: none; box-shadow: 0 4px 16px rgba(102,126,234,0.3);">
                        <i class="bi bi-send"></i> 发布留言
                    </button>
                    <a href="/Message/Index" class="btn btn-outline-secondary btn-lg rounded-pill px-4">
                        返回大屏
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // 字数统计
        document.querySelector('textarea[name="Content"]').addEventListener('input', function() {
            document.getElementById('charCount').textContent = this.value.length;
        });
    </script>
}