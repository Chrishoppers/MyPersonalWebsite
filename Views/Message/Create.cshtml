@model MyPersonalWebsite.Models.Message

@{
    ViewData["Title"] = "发布留言";
    var username = Context.Session.GetString("Username") ?? "用户";
    var userEmail = Context.Session.GetString("UserEmail") ?? "";
}

<div style="max-width:700px;margin:2rem auto;padding:0 1rem;">
    <div style="background:rgba(255,255,255,0.02);backdrop-filter:blur(20px);border-radius:24px;border:1px solid rgba(255,255,255,0.04);padding:2rem;">
        <h2 style="color:#fff;font-weight:700;margin-bottom:0.5rem;">✍️ 发布留言</h2>
        <p style="color:rgba(255,255,255,0.3);margin-bottom:1.5rem;">分享你的想法，连接彼此</p>

        @if (TempData["Success"] != null)
        {
            <div style="background:rgba(40,167,69,0.1);border:1px solid rgba(40,167,69,0.2);border-radius:12px;padding:0.8rem 1.2rem;color:#28a745;margin-bottom:1rem;">
                @TempData["Success"]
            </div>
        }

        @if (!ViewData.ModelState.IsValid)
        {
            <div style="background:rgba(220,53,69,0.1);border:1px solid rgba(220,53,69,0.2);border-radius:12px;padding:0.8rem 1.2rem;color:#dc3545;margin-bottom:1rem;">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <p class="mb-0">@error.ErrorMessage</p>
                }
            </div>
        }

        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div style="margin-bottom:1rem;">
                <label style="display:block;color:rgba(255,255,255,0.6);font-size:0.85rem;font-weight:500;margin-bottom:0.3rem;">显示名称</label>
                <input type="text" class="form-control" value="@username" disabled style="width:100%;padding:0.7rem 1rem;border-radius:12px;border:1px solid rgba(255,255,255,0.06);background:rgba(255,255,255,0.02);color:#fff;font-size:0.95rem;" />
                <small style="color:rgba(255,255,255,0.15);font-size:0.75rem;">使用你的用户名显示</small>
            </div>

            <div style="margin-bottom:1rem;">
                <label style="display:block;color:rgba(255,255,255,0.6);font-size:0.85rem;font-weight:500;margin-bottom:0.3rem;">邮箱</label>
                <input type="email" class="form-control" value="@userEmail" disabled style="width:100%;padding:0.7rem 1rem;border-radius:12px;border:1px solid rgba(255,255,255,0.06);background:rgba(255,255,255,0.02);color:#fff;font-size:0.95rem;" />
                <small style="color:rgba(255,255,255,0.15);font-size:0.75rem;">管理员回复将通过此邮箱通知您</small>
            </div>

            <div style="margin-bottom:1.5rem;">
                <label asp-for="Content" style="display:block;color:rgba(255,255,255,0.6);font-size:0.85rem;font-weight:500;margin-bottom:0.3rem;">留言内容</label>
                <textarea asp-for="Content" rows="6" placeholder="写下你想说的话..." style="width:100%;padding:0.8rem 1rem;border-radius:12px;border:1px solid rgba(255,255,255,0.06);background:rgba(255,255,255,0.02);color:#fff;font-size:0.95rem;resize:vertical;font-family:inherit;" maxlength="500"></textarea>
                <span asp-validation-for="Content" class="text-danger"></span>
                <div style="text-align:right;color:rgba(255,255,255,0.15);font-size:0.75rem;margin-top:0.2rem;">
                    <span id="charCount">0</span>/500
                </div>
            </div>

            <div style="display:flex;gap:1rem;flex-wrap:wrap;">
                <button type="submit" style="flex:1;padding:0.8rem 2rem;border:none;border-radius:40px;background:linear-gradient(135deg,#8B5CF6,#EC4899);color:#fff;font-weight:600;font-size:0.95rem;cursor:pointer;transition:all 0.3s ease;min-width:150px;">
                    ✍️ 发布留言
                </button>
                <a href="/Message/Index" style="padding:0.8rem 2rem;border-radius:40px;border:1px solid rgba(255,255,255,0.06);background:rgba(255,255,255,0.02);color:rgba(255,255,255,0.3);text-decoration:none;font-size:0.9rem;transition:all 0.3s ease;text-align:center;min-width:120px;">
                    返回大屏
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelector('textarea[name="Content"]')?.addEventListener('input', function() {
            document.getElementById('charCount').textContent = this.value.length;
        });
    </script>
}
