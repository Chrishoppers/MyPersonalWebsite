@model List<MyPersonalWebsite.Models.Message>

@{
    ViewData["Title"] = "留言大屏";
    var currentUserId = ViewBag.CurrentUserId as int?;
    var isAdmin = ViewBag.IsAdmin as int? ?? 0;
}

<div style="max-width:900px;margin:0 auto;padding:2rem 1rem;">
    <h1 style="text-align:center;font-size:2.5rem;font-weight:700;background:linear-gradient(135deg,#8B5CF6,#EC4899,#F59E0B);-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin-bottom:2rem;">💬 留言大屏</h1>

    @if (Model != null && Model.Any())
    {
        @foreach (var msg in Model)
        {
            <div style="background:rgba(255,255,255,0.02);backdrop-filter:blur(20px);border-radius:20px;border:1px solid rgba(255,255,255,0.04);padding:1.5rem 2rem;margin-bottom:1.5rem;">
                <div style="display:flex;align-items:center;gap:1rem;margin-bottom:0.5rem;">
                    <div style="width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,#8B5CF6,#EC4899);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:600;font-size:1rem;flex-shrink:0;">
                        @(msg.VisitorName?.FirstOrDefault().ToString().ToUpper() ?? "?")
                    </div>
                    <div>
                        <span style="font-weight:600;color:#fff;">@msg.VisitorName</span>
                        <div style="font-size:0.8rem;color:rgba(255,255,255,0.2);">@msg.CreateTime.ToString("yyyy-MM-dd HH:mm")</div>
                    </div>
                </div>

                <div style="color:rgba(255,255,255,0.7);line-height:1.7;margin:0.5rem 0 0.8rem;">@msg.Content</div>

                <div style="display:flex;align-items:center;gap:1rem;padding-top:0.5rem;border-top:1px solid rgba(255,255,255,0.03);">
                    @if (currentUserId.HasValue && currentUserId.Value != msg.UserId)
                    {
                        <button onclick="toggleLike(@msg.Id, this)" style="background:none;border:none;color:rgba(255,255,255,0.3);cursor:pointer;font-size:0.9rem;display:flex;align-items:center;gap:0.3rem;">
                            ❤️ <span id="likeCount-@msg.Id">@msg.LikeCount</span>
                        </button>
                    }
                    else
                    {
                        <span style="color:rgba(255,255,255,0.2);font-size:0.9rem;">❤️ @msg.LikeCount</span>
                    }

                    @if (isAdmin == 1)
                    {
                        <button onclick="deleteMessage(@msg.Id)" style="background:none;border:none;color:rgba(255,255,255,0.15);cursor:pointer;font-size:0.8rem;">🗑️ 删除</button>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <div style="text-align:center;padding:3rem 2rem;color:rgba(255,255,255,0.15);">💬 还没有留言，快来抢沙发吧！</div>
    }
</div>

<script>
    function toggleLike(messageId, btn) {
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        fetch('/Message/ToggleLike', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': token
            },
            body: `messageId=${messageId}`
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                const countEl = document.getElementById(`likeCount-${messageId}`);
                if (countEl) {
                    countEl.textContent = data.likeCount;
                }
            }
        });
    }

    function deleteMessage(messageId) {
        if (!confirm('确定删除这条留言吗？')) return;
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        fetch('/Message/Delete', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': token
            },
            body: `id=${messageId}`
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                const card = document.getElementById(`msg-${messageId}`);
                if (card) card.remove();
            }
        });
    }
</script>
