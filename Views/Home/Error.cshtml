@model MyPersonalWebsite.Models.ErrorViewModel
@{
    ViewData["Title"] = "错误";
}

<div class="text-center py-5">
    <div style="font-size: 5rem; color: #dc3545;">
        <i class="bi bi-exclamation-triangle-fill"></i>
    </div>
    <h1 class="mt-3 text-danger">出错了！</h1>
    <p class="lead">处理您的请求时发生了错误，请稍后重试。</p>

    @if (Model.ShowRequestId)
    {
        <p>
            <strong>请求 ID:</strong> <code>@Model.RequestId</code>
        </p>
    }

    <div class="mt-4">
        <a href="/" class="btn btn-primary">
            <i class="bi bi-house"></i> 返回首页
        </a>
        <a href="javascript:history.back()" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> 返回上一页
        </a>
    </div>
</div>