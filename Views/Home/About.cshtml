@{
    ViewData["Title"] = "关于我";
    var sections = ViewBag.Sections as List<MyPersonalWebsite.Models.AboutMe>;
    var socialSection = sections?.FirstOrDefault(s => s.SectionKey == "social");
    var socialLinks = socialSection?.Content?.Split('|') ?? new string[0];
    var userId = Context.Session.GetInt32("UserId");
    var isAdmin = Context.Session.GetInt32("IsAdmin") ?? 0;
    var currentUser = ViewBag.CurrentUser as MyPersonalWebsite.Models.User;
    // ⭐ 获取管理员信息
    var adminUser = ViewBag.AdminUser as MyPersonalWebsite.Models.User;
}

<link rel="stylesheet" href="~/css/about.css" />

<style>
    .about-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 1rem 0;
    }

    .about-header {
        text-align: center;
        margin-bottom: 2.5rem;
    }

    .about-header h1 {
        font-size: 2.8rem;
        font-weight: 800;
        background: linear-gradient(135deg, #8B5CF6 0%, #EC4899 50%, #F59E0B 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 0.3rem;
    }

    .about-header p {
        color: rgba(255,255,255,0.3);
        font-size: 1rem;
    }

    .about-card {
        background: rgba(255,255,255,0.02);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.04);
        border-radius: 20px;
        padding: 2rem 2.2rem;
        margin-bottom: 1.5rem;
        transition: all 0.3s ease;
    }

    .about-card:hover {
        background: rgba(255,255,255,0.03);
        border-color: rgba(108,60,225,0.08);
    }

    .about-card .card-icon {
        font-size: 1.8rem;
        margin-bottom: 0.3rem;
    }

    .about-card h4 {
        color: #fff;
        font-weight: 600;
        margin-bottom: 0.5rem;
        font-size: 1.1rem;
    }

    .about-card p {
        color: rgba(255,255,255,0.5);
        line-height: 1.7;
        margin-bottom: 0;
        white-space: pre-wrap;
    }

    .profile-card {
        background: rgba(255,255,255,0.02);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.04);
        border-radius: 20px;
        padding: 2rem 1.5rem;
        text-align: center;
        transition: all 0.3s ease;
        height: 100%;
    }

    .profile-card:hover {
        background: rgba(255,255,255,0.03);
        border-color: rgba(108,60,225,0.08);
        transform: translateY(-4px);
    }

    .profile-card .avatar-container {
        width: 120px;
        height: 120px;
        margin: 0 auto 1rem;
        border-radius: 50%;
        overflow: hidden;
        border: 2px solid rgba(255,255,255,0.06);
    }

    .profile-card .avatar-container img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .profile-card .avatar-container .avatar-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        font-weight: 700;
        color: rgba(255,255,255,0.3);
        background: linear-gradient(135deg, rgba(139,92,246,0.15), rgba(236,72,153,0.15));
    }

    .profile-card h5 {
        color: #fff;
        font-weight: 600;
        font-size: 1.2rem;
        margin-bottom: 0.2rem;
    }

    .profile-card .role {
        color: rgba(255,255,255,0.3);
        font-size: 0.9rem;
        margin-bottom: 0.5rem;
    }

    .profile-card .social-links {
        display: flex;
        justify-content: center;
        gap: 0.8rem;
        flex-wrap: wrap;
        margin-top: 0.5rem;
    }

    .profile-card .social-links a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.04);
        color: rgba(255,255,255,0.4);
        transition: all 0.3s ease;
        text-decoration: none;
        font-size: 1rem;
    }

    .profile-card .social-links a:hover {
        background: rgba(108,60,225,0.1);
        border-color: rgba(108,60,225,0.15);
        color: #8B5CF6;
        transform: translateY(-3px);
    }

    .toast-container {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        z-index: 2000;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        align-items: flex-end;
    }

    .toast-msg {
        padding: 0.8rem 1.8rem;
        border-radius: 40px;
        color: #fff;
        font-weight: 500;
        animation: slideUp 0.4s ease;
        font-size: 0.9rem;
        backdrop-filter: blur(10px);
        background: rgba(0,0,0,0.6);
        border: 1px solid rgba(255,255,255,0.04);
    }

    .toast-msg.success { background: rgba(40,167,69,0.8); }
    .toast-msg.error { background: rgba(220,53,69,0.8); }
    .toast-msg.info { background: rgba(79,172,254,0.8); }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(20px) scale(0.95); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }

    @@media (max-width: 768px) {
        .about-header h1 { font-size: 2rem; }
        .about-card { padding: 1.5rem; }
        .profile-card .avatar-container { width: 90px; height: 90px; }
        .about-container { padding: 0.5rem 0; }
    }
</style>

<div class="about-container">

    <div class="about-header">
        <h1>✨ 关于我</h1>
        <p>了解我的故事、技能和愿景</p>
    </div>

    <div class="row g-4">

        <div class="col-md-8">
            @if (sections != null)
            {
                foreach (var sec in sections.Where(s => s.SectionKey != "social"))
                {
                    <div class="about-card">
                        <div class="card-icon">@sec.Title.Split(' ').FirstOrDefault()</div>
                        <h4>@sec.Title</h4>
                        <p>@Html.Raw(sec.Content.Replace("\n", "<br />"))</p>
                    </div>
                }
            }
        </div>

        <div class="col-md-4">
            <div class="profile-card">

                <!-- ⭐ 显示管理员的头像 -->
                <div class="avatar-container">
                    @if (adminUser != null && !string.IsNullOrEmpty(adminUser.AvatarUrl) && adminUser.IsAvatarApproved)
                    {
                        <img src="@adminUser.AvatarUrl" alt="@adminUser.Username" />
                    }
                    else if (adminUser != null && !string.IsNullOrEmpty(adminUser.AvatarUrl) && !adminUser.IsAvatarApproved)
                    {
                        <img src="@adminUser.AvatarUrl" alt="@adminUser.Username" style="opacity:0.3;filter:grayscale(1);" />
                    }
                    else
                    {
                        <div class="avatar-placeholder">ch</div>
                    }
                </div>

                <h5>@(adminUser?.Username ?? "Chris hopper")</h5>
                <div class="role">👑 管理员</div>

                <div class="social-links">
                    @foreach (var link in socialLinks)
                    {
                        var parts = link.Split(':');
                        if (parts.Length == 2)
                        {
                            var icon = parts[0].ToLower();
                            var url = parts[1];
                            var iconMap = new Dictionary<string, string> {
                                { "github", "bi-github" },
                                { "twitter", "bi-twitter-x" },
                                { "linkedin", "bi-linkedin" },
                                { "discord", "bi-discord" }
                            };
                            var iconClass = iconMap.ContainsKey(icon) ? iconMap[icon] : "bi-link-45deg";
                            <a href="@url" target="_blank" title="@icon">
                                <i class="bi @iconClass"></i>
                            </a>
                        }
                    }
                </div>

                <div style="margin-top:1.2rem;padding-top:1rem;border-top:1px solid rgba(255,255,255,0.03);">
                    <span style="color:rgba(255,255,255,0.15);font-size:0.7rem;">✨ 持续学习 · 不断成长</span>
                </div>

            </div>
        </div>

    </div>
</div>

<div class="toast-container" id="toastContainer"></div>
