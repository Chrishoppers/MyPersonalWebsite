@{
    ViewData["Title"] = "关于我";
    var sections = ViewBag.Sections as List<MyPersonalWebsite.Models.AboutMe>;
    var socialSection = sections?.FirstOrDefault(s => s.SectionKey == "social");
    var socialLinks = socialSection?.Content?.Split('|') ?? new string[0];
    var userId = Context.Session.GetInt32("UserId");
    var isAdmin = Context.Session.GetInt32("IsAdmin") ?? 0;
    var currentUser = ViewBag.CurrentUser as MyPersonalWebsite.Models.User;
}

<link rel="stylesheet" href="~/css/about.css" />

<div class="about-container">

    <div class="about-header">
        <h1>✨ 关于我</h1>
        <p>了解我的故事、技能和愿景</p>
    </div>

    <div class="row g-4">

        <!-- 左侧：内容 -->
        <div class="col-md-8">
            @if (sections != null)
            {
                foreach (var section in sections.Where(s => s.SectionKey != "social"))
                {
                    <div class="about-card">
                        <div class="card-icon">@section.Title.Split(' ').FirstOrDefault()</div>
                        <h4>@section.Title</h4>
                        <p>@Html.Raw(section.Content.Replace("\n", "<br />"))</p>
                    </div>
                }
            }
        </div>

        <!-- 右侧：头像 -->
        <div class="col-md-4">
            <div class="profile-card">

                <div class="avatar-container">
                    @if (currentUser != null && !string.IsNullOrEmpty(currentUser.AvatarUrl) && currentUser.IsAvatarApproved)
                    {
                        <div class="avatar">
                            <img src="@currentUser.AvatarUrl" alt="@currentUser.Username" />
                        </div>
                    }
                    else if (currentUser != null && !string.IsNullOrEmpty(currentUser.AvatarUrl) && !currentUser.IsAvatarApproved)
                    {
                        <div class="avatar">
                            <img src="@currentUser.AvatarUrl" alt="@currentUser.Username" style="opacity:0.3;filter:grayscale(1);" />
                        </div>
                    }
                    else
                    {
                        <div class="avatar">
                            <span id="avatarText">CH</span>
                        </div>
                    }

                    @if (userId.HasValue)
                    {
                        <label class="avatar-upload-btn" title="@(isAdmin == 1 ? "更换头像" : "申请更换头像")">
                            <i class="bi bi-camera"></i>
                            <input type="file" id="avatarInput" accept="image/*" />
                        </label>
                    }
                </div>

                @if (currentUser != null && !string.IsNullOrEmpty(currentUser.AvatarUrl))
                {
                    if (currentUser.IsAvatarApproved)
                    {
                        <span class="avatar-status approved">✅ 头像已通过</span>
                    }
                    else
                    {
                        <span class="avatar-status pending">⏳ 头像审核中</span>
                    }
                }

                <h5>@(currentUser?.Username ?? "Chris Hopper")</h5>
                <div class="role">@(isAdmin == 1 ? "👑 管理员" : "👤 用户")</div>

                <div class="social-links">
                    @foreach (var link in socialLinks)
                    {
                        var parts = link.Split(':');
                        if (parts.Length == 2)
                        {
                            var icon = parts[0].ToLower();
                            var url = parts[1];
                            var iconMap = new Dictionary<string, string> {
                                { "github", "bi-github" },
                                { "twitter", "bi-twitter-x" },
                                { "linkedin", "bi-linkedin" },
                                { "discord", "bi-discord" }
                            };
                            var iconClass = iconMap.ContainsKey(icon) ? iconMap[icon] : "bi-link-45deg";
                            <a href="@url" target="_blank" title="@icon">
                                <i class="bi @iconClass"></i>
                            </a>
                        }
                    }
                </div>

                <div style="margin-top:1.2rem;padding-top:1rem;border-top:1px solid rgba(255,255,255,0.03);">
                    <span style="color:rgba(255,255,255,0.15);font-size:0.7rem;">✨ 持续学习 · 不断成长</span>
                </div>

                @if (isAdmin == 1)
                {
                    var pendingAvatars = ViewBag.PendingAvatars as List<MyPersonalWebsite.Models.User>;
                    if (pendingAvatars != null && pendingAvatars.Any())
                    {
                        <div class="admin-avatar-list">
                            <div style="font-size:0.8rem;color:rgba(255,255,255,0.3);margin-bottom:0.5rem;">
                                📸 待审核头像 (@pendingAvatars.Count)
                            </div>
                            @foreach (var user in pendingAvatars)
                            {
                                <div class="admin-avatar-item" id="avatar-item-@user.Id">
                                    <div class="thumb">
                                        @if (!string.IsNullOrEmpty(user.AvatarUrl))
                                        {
                                            <img src="@user.AvatarUrl" alt="@user.Username" />
                                        }
                                        else
                                        {
                                            <span style="display:flex;align-items:center;justify-content:center;width:100%;height:100%;background:rgba(255,255,255,0.02);font-size:1rem;">?</span>
                                        }
                                    </div>
                                    <div class="info">
                                        <strong>@user.Username</strong>
                                        <span style="font-size:0.7rem;color:rgba(255,255,255,0.15);">
                                            @user.AvatarSubmittedAt?.ToString("MM-dd HH:mm")
                                        </span>
                                    </div>
                                    <div class="actions">
                                        <button class="approve-btn" onclick="approveAvatar(@user.Id, this)">通过</button>
                                        <button class="reject-btn" onclick="rejectAvatar(@user.Id, this)">拒绝</button>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                }

            </div>
        </div>

    </div>
</div>

<div class="toast-container" id="toastContainer"></div>

<script>
    document.getElementById('avatarInput')?.addEventListener('change', function(e) {
        const file = this.files[0];
        if (!file) return;
        if (!file.type.startsWith('image/')) { showToast('请选择图片文件', 'error'); return; }
        if (file.size > 5 * 1024 * 1024) { showToast('图片不能超过 5MB', 'error'); return; }

        const formData = new FormData();
        formData.append('avatar', file);
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

        showToast('上传中...', 'info');
        fetch('/Home/UploadAvatar', {
            method: 'POST',
            headers: { 'RequestVerificationToken': token },
            body: formData
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                const avatarDiv = document.querySelector('.avatar');
                if (avatarDiv) {
                    const img = avatarDiv.querySelector('img');
                    if (img) {
                        img.src = data.url + '?_=' + new Date().getTime();
                        img.style.opacity = '0.3';
                        img.style.filter = 'grayscale(1)';
                    } else {
                        avatarDiv.innerHTML = `<img src="${data.url}?_=${new Date().getTime()}" alt="头像" style="opacity:0.3;filter:grayscale(1);" />`;
                    }
                }
                const statusSpan = document.querySelector('.avatar-status');
                if (statusSpan) {
                    statusSpan.className = 'avatar-status pending';
                    statusSpan.textContent = '⏳ 头像审核中';
                }
                showToast('头像已提交，等待审核', 'success');
            } else {
                showToast(data.message || '上传失败', 'error');
            }
        })
        .catch(() => showToast('上传失败，请重试', 'error'));
        this.value = '';
    });

    function approveAvatar(userId, btn) {
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        fetch('/Admin/ApproveAvatar', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': token },
            body: `userId=${userId}`
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                showToast('✅ 头像已审核通过', 'success');
                const item = document.getElementById(`avatar-item-${userId}`);
                if (item) { item.style.opacity = '0.3'; item.style.transition = 'all 0.3s ease'; setTimeout(() => item.remove(), 300); }
            } else {
                showToast(data.message || '操作失败', 'error');
            }
        })
        .catch(() => showToast('操作失败，请重试', 'error'));
    }

    function rejectAvatar(userId, btn) {
        if (!confirm('确定拒绝该用户的头像吗？')) return;
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        fetch('/Admin/RejectAvatar', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': token },
            body: `userId=${userId}`
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                showToast('已拒绝该头像', 'info');
                const item = document.getElementById(`avatar-item-${userId}`);
                if (item) { item.style.opacity = '0.3'; item.style.transition = 'all 0.3s ease'; setTimeout(() => item.remove(), 300); }
            } else {
                showToast(data.message || '操作失败', 'error');
            }
        })
        .catch(() => showToast('操作失败，请重试', 'error'));
    }

    function showToast(message, type = 'info') {
        const container = document.getElementById('toastContainer');
        const toast = document.createElement('div');
        toast.className = `toast-msg ${type}`;
        toast.textContent = message;
        container.appendChild(toast);
        setTimeout(() => { toast.style.opacity = '0'; toast.style.transform = 'translateX(20px)'; setTimeout(() => toast.remove(), 300); }, 3000);
    }
</script>
