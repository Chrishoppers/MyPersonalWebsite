@{
    ViewData["Title"] = "登录";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h4 class="mb-0"><i class="bi bi-box-arrow-in-right"></i> 登录</h4>
                </div>
                <div class="card-body p-4">
                    @if (TempData["Message"] != null)
                    {
                        <div class="alert alert-success">@TempData["Message"]</div>
                    }

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <p class="mb-0">@error.ErrorMessage</p>
                            }
                        </div>
                    }

                    <form asp-action="Login" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-semibold"><i class="bi bi-person"></i> 用户名或邮箱</label>
                            <input type="text" name="username" class="form-control form-control-lg" 
                                   placeholder="请输入用户名或邮箱" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold"><i class="bi bi-lock"></i> 密码</label>
                            <input type="password" name="password" class="form-control form-control-lg" 
                                   placeholder="请输入密码" required />
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100">
                            <i class="bi bi-box-arrow-in-right"></i> 登录
                        </button>
                    </form>

                    <div class="text-center mt-3">
                        <p class="mb-0">还没有账号？ <a href="/Auth/Register" class="text-primary">立即注册</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>