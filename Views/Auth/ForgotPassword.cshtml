@{
    ViewData["Title"] = "忘记密码";
}

<style>
    .auth-container {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1.2rem;
    }

    .auth-card {
        background: rgba(255,255,255,0.02);
        backdrop-filter: blur(40px);
        border: 1px solid rgba(255,255,255,0.04);
        border-radius: 32px;
        padding: 2.8rem 3rem;
        max-width: 420px;
        width: 100%;
    }

    .auth-card .logo {
        text-align: center;
        margin-bottom: 0.5rem;
    }

    .auth-card .logo h2 {
        font-size: 1.8rem;
        font-weight: 800;
        background: linear-gradient(135deg, #8B5CF6 0%, #EC4899 50%, #F59E0B 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin: 0;
    }

    .auth-card .subtitle {
        text-align: center;
        color: rgba(255,255,255,0.2);
        font-size: 0.85rem;
        margin-bottom: 2rem;
    }

    .auth-card .form-group {
        margin-bottom: 1.2rem;
    }

    .auth-card .form-group label {
        display: block;
        color: rgba(255,255,255,0.4);
        font-size: 0.8rem;
        font-weight: 500;
        margin-bottom: 0.3rem;
    }

    .auth-card .form-group input {
        width: 100%;
        padding: 0.8rem 1rem;
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.04);
        background: rgba(255,255,255,0.02);
        color: #fff;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        outline: none;
    }

    .auth-card .form-group input:focus {
        border-color: rgba(108,60,225,0.15);
        background: rgba(255,255,255,0.04);
        box-shadow: 0 0 0 4px rgba(108,60,225,0.04);
    }

    .auth-card .form-group input::placeholder {
        color: rgba(255,255,255,0.08);
    }

    .auth-card .btn-primary {
        width: 100%;
        padding: 0.9rem;
        border: none;
        border-radius: 40px;
        background: linear-gradient(135deg, #8B5CF6 0%, #EC4899 100%);
        color: #fff;
        font-weight: 600;
        font-size: 0.95rem;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-top: 0.5rem;
    }

    .auth-card .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 32px rgba(108,60,225,0.2);
    }

    .auth-card .footer-links {
        text-align: center;
        margin-top: 1.5rem;
        color: rgba(255,255,255,0.12);
        font-size: 0.85rem;
    }

    .auth-card .footer-links a {
        color: rgba(139,92,246,0.6);
        text-decoration: none;
        transition: color 0.3s ease;
    }

    .auth-card .footer-links a:hover {
        color: #8B5CF6;
    }

    .auth-card .alert {
        padding: 0.6rem 1rem;
        border-radius: 12px;
        font-size: 0.85rem;
        margin-bottom: 1rem;
        background: rgba(220,53,69,0.06);
        border: 1px solid rgba(220,53,69,0.06);
        color: rgba(255,255,255,0.4);
    }

    .auth-card .alert-success {
        background: rgba(40,167,69,0.06);
        border-color: rgba(40,167,69,0.06);
        color: rgba(255,255,255,0.4);
    }

    @@media (max-width: 480px) {
        .auth-card {
            padding: 2rem 1.5rem;
        }
    }
</style>

<div class="auth-container">
    <div class="auth-card">
        <div class="logo">
            <h2>🔑 忘记密码</h2>
        </div>
        <p class="subtitle">输入您的邮箱，接收验证码</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <p class="mb-0">@error.ErrorMessage</p>
                }
            </div>
        }

        <form asp-action="ForgotPassword" method="post">
            <div class="form-group">
                <label>邮箱</label>
                <input type="email" name="email" placeholder="输入注册邮箱" required />
            </div>

            <button type="submit" class="btn-primary">发送验证码</button>

            <div class="footer-links">
                记得密码？ <a href="/Auth/Login">返回登录</a>
            </div>
        </form>
    </div>
</div>
