@{
    ViewData["Title"] = "注册";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h4 class="mb-0"><i class="bi bi-person-plus"></i> 注册新账号</h4>
                </div>
                <div class="card-body p-4">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <p class="mb-0">@error.ErrorMessage</p>
                            }
                        </div>
                    }

                    <form asp-action="Register" method="post" id="registerForm">
                        <!-- 用户名 -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold"><i class="bi bi-person"></i> 用户名</label>
                            <input type="text" name="username" class="form-control form-control-lg" 
                                   placeholder="请输入用户名" required />
                        </div>

                        <!-- 邮箱 -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold"><i class="bi bi-envelope"></i> 邮箱</label>
                            <input type="email" name="email" class="form-control form-control-lg" 
                                   placeholder="请输入邮箱" required />
                        </div>

                        <!-- 密码 -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold"><i class="bi bi-lock"></i> 密码</label>
                            <input type="password" name="password" class="form-control form-control-lg" 
                                   placeholder="请设置密码（至少6位）" required minlength="6" />
                        </div>

                        <!-- ===== ⭐ SVG 验证码 ===== -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold"><i class="bi bi-shield-lock"></i> 验证码</label>
                            <div class="d-flex align-items-center gap-2">
                                <img id="captchaImage" src="/Captcha/Index" alt="验证码" 
                                     style="height: 60px; cursor: pointer; border: 1px solid rgba(0,0,0,0.06); border-radius: 8px;" 
                                     onclick="refreshCaptcha()" title="点击刷新验证码" />
                                <button type="button" class="btn btn-outline-secondary" onclick="refreshCaptcha()">
                                    <i class="bi bi-arrow-clockwise"></i> 换一张
                                </button>
                            </div>
                            <div class="mt-2">
                                <input type="text" name="captchaAnswer" class="form-control" 
                                       placeholder="请输入图片中的验证码（不区分大小写）" required maxlength="6" 
                                       style="max-width: 280px;" autocomplete="off" />
                                <small class="text-muted">点击图片可刷新验证码</small>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100">
                            <i class="bi bi-send"></i> 注册并获取验证码
                        </button>
                    </form>

                    <div class="text-center mt-3">
                        <p class="mb-0">已有账号？ <a href="/Auth/Login" class="text-primary">立即登录</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function refreshCaptcha() {
            const img = document.getElementById('captchaImage');
            img.src = '/Captcha/Refresh?_=' + new Date().getTime();
        }
    </script>
}
