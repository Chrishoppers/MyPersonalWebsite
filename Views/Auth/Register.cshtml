@{
    ViewData["Title"] = "注册";
}

<style>
    .auth-container {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1.2rem;
    }

    .auth-card {
        background: rgba(255,255,255,0.02);
        backdrop-filter: blur(40px);
        border: 1px solid rgba(255,255,255,0.04);
        border-radius: 32px;
        padding: 2.8rem 3rem;
        max-width: 440px;
        width: 100%;
        box-shadow: 0 24px 80px rgba(0,0,0,0.3);
        transition: all 0.3s ease;
    }

    .auth-card:hover {
        border-color: rgba(255,255,255,0.06);
    }

    .auth-card .logo {
        text-align: center;
        margin-bottom: 0.5rem;
    }

    .auth-card .logo h2 {
        font-size: 1.8rem;
        font-weight: 800;
        background: linear-gradient(135deg, #8B5CF6 0%, #EC4899 50%, #F59E0B 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin: 0;
    }

    .auth-card .subtitle {
        text-align: center;
        color: rgba(255,255,255,0.2);
        font-size: 0.85rem;
        margin-bottom: 2rem;
    }

    .auth-card .form-group {
        margin-bottom: 1.2rem;
    }

    .auth-card .form-group label {
        display: block;
        color: rgba(255,255,255,0.4);
        font-size: 0.8rem;
        font-weight: 500;
        margin-bottom: 0.3rem;
        letter-spacing: 0.04em;
    }

    .auth-card .form-group .input-wrapper {
        position: relative;
    }

    .auth-card .form-group .input-wrapper .input-icon {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: rgba(255,255,255,0.08);
        font-size: 1rem;
    }

    .auth-card .form-group input {
        width: 100%;
        padding: 0.8rem 1rem 0.8rem 2.8rem;
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.04);
        background: rgba(255,255,255,0.02);
        color: #fff;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        outline: none;
    }

    .auth-card .form-group input::placeholder {
        color: rgba(255,255,255,0.08);
    }

    .auth-card .form-group input:focus {
        border-color: rgba(108,60,225,0.15);
        background: rgba(255,255,255,0.04);
        box-shadow: 0 0 0 4px rgba(108,60,225,0.04);
    }

    .auth-card .form-group .hint {
        color: rgba(255,255,255,0.06);
        font-size: 0.7rem;
        margin-top: 0.2rem;
    }

    /* ⭐ 头像上传 */
    .avatar-upload-area {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.5rem 0;
    }

    .avatar-upload-area .avatar-preview {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        overflow: hidden;
        background: rgba(255,255,255,0.03);
        border: 2px dashed rgba(255,255,255,0.06);
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: rgba(255,255,255,0.1);
        transition: all 0.3s ease;
    }

    .avatar-upload-area .avatar-preview img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .avatar-upload-area .avatar-preview.has-image {
        border-color: rgba(108,60,225,0.15);
    }

    .avatar-upload-area .upload-btn {
        padding: 0.4rem 1.2rem;
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 30px;
        background: rgba(255,255,255,0.02);
        color: rgba(255,255,255,0.3);
        font-size: 0.8rem;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .avatar-upload-area .upload-btn:hover {
        background: rgba(255,255,255,0.04);
        color: rgba(255,255,255,0.5);
    }

    .avatar-upload-area .file-input {
        display: none;
    }

    .avatar-upload-area .hint-text {
        color: rgba(255,255,255,0.08);
        font-size: 0.65rem;
    }

    .auth-card .btn-primary {
        width: 100%;
        padding: 0.9rem;
        border: none;
        border-radius: 40px;
        background: linear-gradient(135deg, #8B5CF6 0%, #EC4899 100%);
        color: #fff;
        font-weight: 600;
        font-size: 0.95rem;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-top: 0.5rem;
    }

    .auth-card .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 32px rgba(108,60,225,0.2);
    }

    .auth-card .btn-primary:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        transform: none;
    }

    .auth-card .footer-links {
        text-align: center;
        margin-top: 1.5rem;
        color: rgba(255,255,255,0.12);
        font-size: 0.85rem;
    }

    .auth-card .footer-links a {
        color: rgba(139,92,246,0.6);
        text-decoration: none;
        transition: color 0.3s ease;
    }

    .auth-card .footer-links a:hover {
        color: #8B5CF6;
    }

    .auth-card .alert {
        padding: 0.6rem 1rem;
        border-radius: 12px;
        font-size: 0.85rem;
        margin-bottom: 1rem;
        background: rgba(220,53,69,0.06);
        border: 1px solid rgba(220,53,69,0.06);
        color: rgba(255,255,255,0.4);
    }

    .auth-card .alert-success {
        background: rgba(40,167,69,0.06);
        border-color: rgba(40,167,69,0.06);
        color: rgba(255,255,255,0.4);
    }

    .captcha-wrapper {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        flex-wrap: wrap;
    }

    .captcha-wrapper img {
        height: 50px;
        border-radius: 12px;
        cursor: pointer;
        border: 1px solid rgba(255,255,255,0.04);
        background: rgba(255,255,255,0.02);
    }

    .captcha-wrapper .captcha-input {
        flex: 1;
        min-width: 120px;
    }

    .captcha-wrapper .captcha-input input {
        padding-left: 1rem;
    }

    .captcha-wrapper .refresh-btn {
        padding: 0.4rem 1rem;
        border-radius: 30px;
        border: 1px solid rgba(255,255,255,0.04);
        background: rgba(255,255,255,0.02);
        color: rgba(255,255,255,0.2);
        cursor: pointer;
        transition: all 0.3s ease;
        font-size: 0.8rem;
    }

    .captcha-wrapper .refresh-btn:hover {
        background: rgba(255,255,255,0.04);
        color: rgba(255,255,255,0.4);
    }

    @@media (max-width: 480px) {
        .auth-card {
            padding: 2rem 1.5rem;
        }
        .captcha-wrapper {
            flex-direction: column;
            align-items: stretch;
        }
        .captcha-wrapper img {
            height: 60px;
            width: 100%;
            object-fit: cover;
        }
        .avatar-upload-area {
            flex-wrap: wrap;
        }
    }
</style>

<div class="auth-container">
    <div class="auth-card">

        <div class="logo">
            <h2>✨ 注册</h2>
        </div>
        <p class="subtitle">创建你的账号</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <p class="mb-0">@error.ErrorMessage</p>
                }
            </div>
        }

        <form asp-action="Register" method="post" enctype="multipart/form-data" id="registerForm">

            <div class="form-group">
                <label>用户名</label>
                <div class="input-wrapper">
                    <span class="input-icon"><i class="bi bi-person"></i></span>
                    <input type="text" name="username" placeholder="输入用户名" required />
                </div>
            </div>

            <div class="form-group">
                <label>邮箱</label>
                <div class="input-wrapper">
                    <span class="input-icon"><i class="bi bi-envelope"></i></span>
                    <input type="email" name="email" placeholder="输入邮箱" required />
                </div>
            </div>

            <div class="form-group">
                <label>密码</label>
                <div class="input-wrapper">
                    <span class="input-icon"><i class="bi bi-lock"></i></span>
                    <input type="password" name="password" placeholder="至少 6 位" required minlength="6" />
                </div>
            </div>

            <!-- ⭐ 头像上传 -->
            <div class="form-group">
                <label>头像</label>
                <div class="avatar-upload-area">
                    <div class="avatar-preview" id="avatarPreview">
                        <span><i class="bi bi-person"></i></span>
                    </div>
                    <div>
                        <button type="button" class="upload-btn" onclick="document.getElementById('avatarInput').click()">
                            📷 选择图片
                        </button>
                        <input type="file" id="avatarInput" name="avatar" class="file-input" accept="image/*" />
                        <div class="hint-text">支持 JPG, PNG, GIF, WebP · 最大 5MB</div>
                    </div>
                </div>
            </div>

            <!-- SVG 验证码 -->
            <div class="form-group">
                <label>验证码</label>
                <div class="captcha-wrapper">
                    <img id="captchaImage" src="/Captcha/Index" alt="验证码" onclick="refreshCaptcha()" title="点击刷新" />
                    <div class="captcha-input">
                        <input type="text" name="captchaAnswer" placeholder="输入验证码" required maxlength="6" style="padding-left:1rem;" autocomplete="off" />
                    </div>
                    <button type="button" class="refresh-btn" onclick="refreshCaptcha()">
                        <i class="bi bi-arrow-clockwise"></i>
                    </button>
                </div>
            </div>

            <button type="submit" class="btn-primary" id="submitBtn">注册</button>

            <div class="footer-links">
                已有账号？ <a href="/Auth/Login">立即登录</a>
            </div>

        </form>

    </div>
</div>

@section Scripts {
    <script>
        // ===== 验证码刷新 =====
        function refreshCaptcha() {
            const img = document.getElementById('captchaImage');
            img.src = '/Captcha/Refresh?_=' + new Date().getTime();
        }

        // ===== 头像预览 =====
        document.getElementById('avatarInput').addEventListener('change', function(e) {
            const file = this.files[0];
            if (!file) return;

            // 验证文件类型
            const allowedTypes = ['image/jpeg', 'image/png', 'image/gif', 'image/webp'];
            if (!allowedTypes.includes(file.type)) {
                alert('只支持 JPG, PNG, GIF, WebP 格式');
                this.value = '';
                return;
            }

            // 验证文件大小（5MB）
            if (file.size > 5 * 1024 * 1024) {
                alert('图片不能超过 5MB');
                this.value = '';
                return;
            }

            // 预览图片
            const reader = new FileReader();
            reader.onload = function(e) {
                const preview = document.getElementById('avatarPreview');
                preview.innerHTML = `<img src="${e.target.result}" alt="头像" />`;
                preview.classList.add('has-image');
            };
            reader.readAsDataURL(file);
        });

        // ===== 提交按钮防重复 =====
        document.getElementById('registerForm').addEventListener('submit', function(e) {
            const btn = document.getElementById('submitBtn');
            btn.disabled = true;
            btn.textContent = '⏳ 注册中...';
        });
    </script>
}
